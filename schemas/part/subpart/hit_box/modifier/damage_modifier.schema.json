{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/part/subpart/hit_box/modifier/damage_modifier.json",
  "title": "伤害修改器",
  "description": "包含多个修改器条目的列表，按顺序应用。每个修改器条目根据条件决定是否生效。",
  "type": "array",
  "items": {
    "$ref": "modifier_entry.schema.json"
  },
  "default": [],
  "examples": [
    [
      {
        "operation": "add",
        "value": -5.0,
        "condition": {
          "type": "damage_type",
          "id": "minecraft:fly_into_wall"
        }
      },
      {
        "operation": "multiply",
        "value": 0.05,
        "condition": {
          "type": "damage_type",
          "id": "minecraft:sweet_berry_bush"
        }
      }
    ]
  ]
}