{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/part/subpart/sub_part_attr.schema.json",
  "title": "子部件属性",
  "description": "定义载具部件中的一个子部件（最小运动单元）的属性，包含物理特性、碰撞检测、连接点和子系统等",
  "type": "object",
  "properties": {
    "start_bone": {
      "type": "string",
      "default": "",
      "description": "子部件的起始骨骼名称，用于从模型中选择要渲染和计算碰撞的骨骼集合。若为空，则使用整个模型的所有骨骼"
    },
    "end_bones": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "结束骨骼名称列表，在起始骨骼和结束骨骼之间的骨骼将被包含在子部件中。用于排除不需要的部分"
    },
    "durability": {
      "type": "number",
      "minimum": 0,
      "default": 20.0,
      "description": "子部件基础生命值，降至0时该子部件的所有子系统会瘫痪。注意：多个子部件可共享耐久度（由部件定义中的share_durability控制）"
    },
    "mass": {
      "type": "number",
      "minimum": 0,
      "default": 25.0,
      "description": "子部件质量(kg)，必须大于0，用于物理计算"
    },
    "mass_center": {
      "type": "string",
      "default": "mass_center",
      "description": "质心定位器名称，用于指定模型中的同名定位器作为质心位置。若未指定或未找到定位器，则会以碰撞体积的几何中心作为质心。"
    },
    "projected_area": {
      "$ref": "../../base/vector_3d.schema.json",
      "default": {"x": 0, "y": 0, "z": 0},
      "description": "子部件在三个轴向上的投影面积(m²)，用于计算空气阻力"
    },
    "block_collision": {
      "type": "string",
      "enum": ["true", "false", "ground"],
      "default": "true",
      "description": "地形碰撞模式：true（默认，与所有方块碰撞），ground（仅与部件之下的地面方块碰撞），false（不与任何方块碰撞）"
    },
    "collision_height": {
      "type": "number",
      "default": -1.0,
      "description": "碰撞检测高度(m)，遭遇的障碍小于此高度时不与障碍发生碰撞（方块碰撞模式需要为ground）。默认-1.0表示所有障碍均碰撞"
    },
    "climb_assist": {
      "type": "boolean",
      "default": false,
      "description": "攀爬辅助，是否启用攀爬辅助功能"
    },
    "hit_boxes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "hit_box/hit_box_attr.schema.json"
      },
      "default": {},
      "minProperties": 1,
      "description": "碰撞箱定义，键为骨骼名称，会寻找名称匹配的骨骼，并根据其中的方块创建不同形状的碰撞体。每个子部件至少需要一个碰撞箱"
    },
    "interact_boxes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "interact_box_attr.schema.json"
      },
      "default": {},
      "description": "交互箱定义，键为交互箱名称，值为交互箱属性。用于定义玩家可以交互的区域"
    },
    "connectors": {
      "type": "object",
      "additionalProperties": {
        "$ref": "connector/connector_attr.schema.json"
      },
      "default": {},
      "description": "连接点列表，子部件用于与其他部件连接的接口定义"
    },
    "subsystems": {
      "type": "object",
      "additionalProperties": {
        "$ref": "../../subsystem/subsystem_dynamic_attr.schema.json"
      },
      "default": {},
      "description": "子系统定义，键为子系统名称，值为子系统动态属性。定义子部件与连接点、其他子系统的交互关系"
    },
    "hydro_priority": {
      "type": "integer",
      "default": 0,
      "description": "空气阻力计算优先级，值越大优先级越高。优先级高或相等的部件会遮挡优先级低或相等的部件，导致阻力系数发生变化"
    },
    "hydrodynamics": {
      "type": "object",
      "additionalProperties": {
        "$ref": "hydrodynamic_attr.schema.json"
      },
      "default": {
        "": {}
      },
      "description": "流体动力计算定位点列表，键值对的键名优先作为骨骼名称查找，若找到对应骨骼则使用该骨骼内的所有定位器作为气动计算点；若未找到对应骨骼，则作为定位器名称查找。空字符串表示以质心位置计算。每个定位点的属性定义参考hydrodynamic_attr.schema.json。"
    }
  },
  "required": ["hit_boxes"],
  "examples": [
    {
      "hit_boxes": {
        "mmCollision_Box_Chassis": {
          "name": "chassis",
          "type": "box"
        }
      },
      "description": "最简子部件示例，仅包含必需的碰撞箱定义"
    },
    {
      "start_bone": "chassis",
      "end_bones": ["engine"],
      "mass_center": "hull_mass_center",
      "durability": 550.0,
      "mass": 1200.0,
      "projected_area": {
        "x": 1.5,
        "y": 0.8,
        "z": 3.2
      },
      "block_collision": "ground",
      "collision_height": 2.5,
      "climb_assist": true,
      "hit_boxes": {
        "mmCollision_Box_Chassis": {
          "name": "chassis",
          "type": "box",
          "block_damage_factor": 1.5,
          "angle_effect": true,
          "thickness": 10
        },
        "mmCollision_Box_Engine": {
          "name": "engine",
          "type": "box",
          "subsystem": "engine",
          "block_damage_factor": 0.95,
          "angle_effect": true,
          "thickness": 3
        }
      },
      "interact_boxes": {
        "driver_seat": {
          "bone_name": "driver_seat",
          "interact_type": "seat"
        }
      },
      "connectors": {
        "wheel_front_left": {
          "locator": "wheel_front_left",
          "type": "Advanced"
        },
        "wheel_front_right": {
          "locator": "wheel_front_right",
          "type": "Advanced"
        }
      },
      "subsystems": {
        "driver_seat": {
          "type": "machine_max:seat",
          "definition": "machine_max:default_seat",
          "locator": "driver_seat_point",
          "move_outputs": {
            "move_control": ["car_controller"]
          },
          "regular_outputs": {
            "regular_control": ["car_controller"]
          },
          "aim_outputs": {
            "aim_control": ["car_controller"]
          }
        },
        "passenger_seat": {
          "type": "machine_max:seat",
          "definition": "machine_max:default_passenger_seat",
          "locator": "passenger_seat_point"
        },
        "car_controller": {
          "type": "machine_max:car_controller",
          "definition": "machine_max:default_car_controller"
        },
        "engine": {
          "type": "machine_max:engine",
          "definition": "machine_max:default_engine"
        },
        "gearbox": {
          "type": "machine_max:gearbox",
          "definition": "machine_max:default_gearbox"
        },
        "trunk_storage": {
          "type": "machine_max:item_storage",
          "definition": "machine_max:default_trunk"
        },
        "glove_box": {
          "type": "machine_max:item_storage",
          "definition": "machine_max:glove_box"
        },
        "left_front_wheel_driver": {
          "type": "machine_max:wheel_driver",
          "definition": "machine_max:default_wheel_driver",
          "connector": "wheel_front_left"
        },
        "right_front_wheel_driver": {
          "type": "machine_max:wheel_driver",
          "definition": "machine_max:default_wheel_driver",
          "connector": "wheel_front_right"
        }
      },
      "hydro_priority": 0,
      "hydrodynamics": {
        "hull_aero": {
          "drag_coefficient": 0.3,
          "lift_coefficient": 0.1
        }
      },
      "description": "完整子部件示例，包含质心定位器、流体动力、连接点及完整的子系统配置（座位、储物、控制器、发动机、变速箱等）"
    }
  ]
}
