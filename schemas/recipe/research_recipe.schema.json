{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/recipe/research_recipe.schema.json",
  "title": "Machine-Max Research Recipe",
  "description": "Schema for machine_max:research recipe.",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "type": { "type": "string", "const": "machine_max:research" },
    "research_cost": { "type": "integer", "minimum": 0 },
    "research_ingredients": {
      "type": "array",
      "items": { "$ref": "#/definitions/ingredient_count_pair" },
      "default": []
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "icon": { "$ref": "#/definitions/resource_location" },
    "description": { "type": "string", "default": "" }
  },
  "required": ["type", "research_cost"],
  "additionalProperties": false,
  "definitions": {
    "ingredient_selector": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^#?[a-z0-9_.-]+:[a-z0-9_./-]+$"
        },
        {
          "type": "object",
          "properties": {
            "item": { "type": "string" },
            "tag": { "type": "string" }
          },
          "anyOf": [{ "required": ["item"] }, { "required": ["tag"] }],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "neoforge:ingredient_type": { "type": "string" }
          },
          "anyOf": [{ "required": ["type"] }, { "required": ["neoforge:ingredient_type"] }],
          "additionalProperties": true
        }
      ]
    },    "ingredient_count_pair": {
      "type": "object",
      "properties": {
        "ingredient": { "$ref": "#/definitions/ingredient_selector" },
        "count": { "type": "integer", "minimum": 0 }
      },
      "required": ["ingredient", "count"],
      "additionalProperties": false
    },
    "resource_location": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+:[a-z0-9_./-]+$"
    }
  }
}

