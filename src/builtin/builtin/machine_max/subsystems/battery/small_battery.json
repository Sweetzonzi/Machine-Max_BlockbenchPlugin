{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:battery", //电池子系统, 小容量电池(如微型电动车/卡丁车)
  "basic_durability": 20, //(可选, 默认20.0)子系统基础耐久度, 降至0时会瘫痪
  "max_stored_energy": 20000, //最大储能(J), 约20kJ, 适合短途代步
  "max_charge_rate": 500, //最大充电速率(W), 约500W
  "max_discharge_rate": 1000 //最大放电速率(W), 约1000W
}
