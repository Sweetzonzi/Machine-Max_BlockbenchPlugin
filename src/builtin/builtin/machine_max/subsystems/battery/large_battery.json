{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:battery", //电池子系统, 大容量电池(如高性能电动车/重型车)
  "basic_durability": 100, //(可选, 默认20.0)子系统基础耐久度, 降至0时会瘫痪
  "max_stored_energy": 500000, //最大储能(J), 约500kJ, 适合长途/重载
  "max_charge_rate": 5000, //最大充电速率(W), 约5000W
  "max_discharge_rate": 10000 //最大放电速率(W), 约10000W
}
