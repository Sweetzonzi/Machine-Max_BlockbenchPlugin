{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:motorbike_controller", //摩托车控制器，适用于运动摩托车/街车，参考R700
  "basic_durability": 60, //(可选, 默认20.0)子系统基础耐久度，降至0时会瘫痪
  "steering_center": [0, -0.5, 0.85], //(可选, 默认[0,0,0])转向中心位置(m)，相对部件局部坐标系，y值表示接地处相对质心的垂直偏移
  "min_steering_radius": 3.5, //(可选, 默认3.0)最小转向半径(m)，用于低速和手刹时的转向限制
  "lateral_acceleration": 20, //(可选, 默认8.0)侧向加速度限制(m/s²)，用于根据速度实时计算转向半径（半径=速度²/加速度）
  "max_drift_angular_velocity": 1.8, //(可选, 默认1.0)最大漂移角速度(rad/s)，作为漂移时PD控制器的目标值
  "max_angle": 35, //(可选, 默认30.0)最大安全倾斜角(°)，超过此角度不再修正姿态
  "parking_angle": 5, //(可选, 默认5.0)静态停放倾斜角(°)，正值向左倾斜，模拟侧撑
  "correction_force_multiplier": 1.0 //(可选, 默认1.0)修正力倍率，整体缩放平衡调节力
}
