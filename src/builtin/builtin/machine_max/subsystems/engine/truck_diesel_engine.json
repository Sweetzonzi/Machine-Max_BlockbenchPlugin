{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:engine", //引擎子系统
  "basic_durability": 400, //(可选, 默认20.0)子系统基础耐久度, 降至0时会瘫痪
  "max_power": 370000, //最大功率(W), 约370kW, 仿大运卡车柴油机
  "max_torque": 2500, //(可选, 默认100)峰值扭矩(N·m), 约2500N·m, 低转速大扭矩
  "idle_rpm": 550, //(可选, 默认500.0)怠速转速(RPM)
  "max_torque_rpm": 1500, //(可选, 默认5200.0)达到最大扭矩的转速(RPM), 柴油机低转大扭矩特性
  "red_line_rpm": 2200, //(可选, 默认7500.0)红线转速(RPM), 柴油机转速较低
  "red_line_torque_ratio": 0.9, //(可选, 默认0.9)红线转速时扭矩与最大扭矩比值
  "inertia": 50, //(可选, 默认10.0)转动惯量(kg·m²), 大惯量适应重载
  "cylinder": 6, //(可选, 默认4)气缸数, 影响发动机音效
  "damping_factors": [5.0, 0.05, 0.00001] //(可选, 默认[20.0, 0.1, 0.00005])发动机各阶阻力系数
}
