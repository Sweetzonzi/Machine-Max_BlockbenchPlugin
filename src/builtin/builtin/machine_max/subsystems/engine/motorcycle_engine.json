{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:engine", //引擎子系统
  "basic_durability": 30, //(可选, 默认20.0)子系统基础耐久度, 降至0时会瘫痪
  "max_power": 6000, //最大功率(W), 约6kW, 仿R700摩托车
  "max_torque": 9, //(可选, 默认100)峰值扭矩(N·m), 约9N·m
  "idle_rpm": 500, //(可选, 默认500.0)怠速转速(RPM)
  "max_torque_rpm": 7000, //(可选, 默认5200.0)达到最大扭矩的转速(RPM), 高转特性
  "red_line_rpm": 9500, //(可选, 默认7500.0)红线转速(RPM), 高转引擎
  "red_line_torque_ratio": 0.7, //(可选, 默认0.9)红线转速时扭矩与最大扭矩比值
  "inertia": 2, //(可选, 默认10.0)转动惯量(kg·m²), 小惯量响应快
  "cylinder": 1, //(可选, 默认4)气缸数, 单缸
  "damping_factors": [1.0, 0.02, 0.00001] //(可选, 默认[20.0, 0.1, 0.00005])发动机各阶阻力系数
}
