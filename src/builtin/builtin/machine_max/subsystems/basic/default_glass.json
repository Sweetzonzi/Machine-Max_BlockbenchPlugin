{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:basic",
  "basic_durability": 2, // (可选, 默认20.0)子系统基础耐久度, 降至0时会瘫痪
  "pass_damage": false, // (可选, 默认true)是否令子系统传递伤害至其持有者(零件）
  "limit_damage": false, // (可选, 默认false)是否限制子系统传递的伤害不超过其剩余耐久度
  "sounds": {
    "on_destroyed": { // (可选, 默认"block.glass.break")子系统破坏音效
      "sound_id": "machine_max:subsystem.baisc.glass.break",
      "range": 32
    }
  },
  "hidden": true // (可选, 默认false)是否在HUD等处隐藏子系统信息的显示，避免此类无功能子系统干扰玩家
}