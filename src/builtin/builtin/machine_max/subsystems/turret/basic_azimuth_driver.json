{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:turret_driver", //炮塔驱动器，可配置方向机(Yaw)和/或高低机(Pitch)轴
  "basic_durability": 200, //方向机基座耐久度，需承受炮塔回转冲击
  "yaw": { //偏航轴（方向机），水平方向回转驱动参数
    "max_force": 80000, //最大驱动力矩(N·m)，80kN·m足以驱动中型炮塔回转
    "max_speed": 45.0 //最大角速度(°/s)，45°/s为中等回转速度，兼顾响应与瞄准精度
  },
  "control_inputs": ["weapon_control"] //(可选, 默认["weapon_control"])控制信号输入频道，接收武器控制器下发的RotationSignal
}
