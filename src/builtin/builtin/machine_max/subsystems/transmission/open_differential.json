{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:transmission", //传动子系统, 将接收到的功率分配至各个输出目标
  "basic_durability": 200, //(可选, 默认20.0)子系统基础耐久度, 降至0时会瘫痪, 开放式差速器结构简单耐久适中
  "diff_lock": "false", //(可选, 默认auto)差速锁模式: false=开放差速器, 各输出端扭矩相同但转速可自由差速
  "diff_lock_sensitivity": 0.85 //(可选, 默认1.0)差速锁灵敏度, 开放模式下仍保留基础差速调校
}
