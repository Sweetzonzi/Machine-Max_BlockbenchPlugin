{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:motor", //电动机子系统, 中型电动机(如卡丁车/轻型车), 仿Kluo电机参数
  "basic_durability": 80, //(可选, 默认20.0)子系统基础耐久度, 降至0时会瘫痪
  "max_power": 50000, //最大功率(W), 约50kW
  "max_torque": 250, //(可选, 默认100)峰值扭矩(N·m)
  "red_line_rpm": 10000, //(可选, 默认10000)红线转速(RPM)
  "red_line_power_ratio": 0.8, //(可选, 默认0.8)红线转速处功率占峰值功率比例(0~1)
  "inertia": 5, //(可选, 默认10)转动惯量(kg·m²)
  "damping_factors": [10.0, 0.1, 0.0001], //(可选, 默认[10.0, 0.1, 0.00005])电机系统各阶阻力系数
  "generator_efficiency": 0.85 //(可选, 默认0.85)发电效率(0~1)
}
