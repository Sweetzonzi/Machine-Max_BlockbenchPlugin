{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:car_controller", //轿车控制器子系统, 适用于大多数公路轿车 (参考AE86参数综合平衡)
  "basic_durability": 150, //(可选, 默认20.0)子系统基础耐久度, 降至0时会瘫痪
  "min_steering_radius": 5.0, //最小转弯半径 (m), 值越小转向越灵活
  "lateral_acceleration": 50, //最大侧向加速度 (m/s²), 决定过弯极限
  "max_drift_angular_velocity": 2.0, //最大漂移角速度 (rad/s), 控制漂移时车身旋转的快慢
  "manual_gear_shift": false, //(可选, 默认false)是否启用手动换挡
  "auto_hand_brake": true, //(可选, 默认false)是否自动拉手刹 (停车时自动制动)
  "drift_assist": true //(可选, 默认false)是否启用漂移辅助, 帮助更容易维持漂移姿态
}
