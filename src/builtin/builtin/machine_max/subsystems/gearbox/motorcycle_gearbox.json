{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:gearbox", //子系统类型：变速箱
  "basic_durability": 40, //基础耐久度，仿R700摩托车变速箱，轻量化耐久较低
  "final_ratio": 15.0, //最终减速比，摩托车通常匹配高转速引擎，最终比较大
  "ratios": [-3.5, 3.5, 2.8, 2.0, 1.4], //减速比列表，首项为倒挡(-3.5)，后4项为1~4前进挡
