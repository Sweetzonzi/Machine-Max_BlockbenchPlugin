{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/subsystem/static/seat_static_attr.json",
  "title": "座椅子系统静态属性",
  "description": "座椅的静态属性，包括乘客显示、伤害阻挡、视角设置等。",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema引用路径，用于编辑器智能提示和验证",
      "default": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json"
    },
    "type": {
      "type": "string",
      "const": "machine_max:seat",
      "description": "子系统类型，必须为'machine_max:seat'。"
    },
    "basic_durability": {
      "type": "number",
      "minimum": 0,
      "default": 20.0,
      "description": "子系统基础耐久度，降至0时会瘫痪，修复至30%耐久度时恢复功能。"
    },
    "pass_damage": {
      "type": "boolean",
      "default": true,
      "description": "是否传递伤害至子系统持有者。若为true，子系统受到的伤害会传递给零件。"
    },
    "limit_damage": {
      "type": "boolean",
      "default": false,
      "description": "是否限制伤害传递值至子系统剩余耐久度。例如40伤害，子系统剩余耐久度为20，则只会传递20伤害给持有者。"
    },
    "hidden": {
      "type": "boolean",
      "default": false,
      "description": "是否隐藏子系统在HUD等处的显示，常用于纯粹提供模型部位损坏差分的无功能子系统"
    },
    "block_damage": {
      "type": "boolean",
      "default": false,
      "description": "是否将乘客受到的伤害转嫁给部件。若为true，则乘客受到的伤害会传递给部件。"
    },
    "render_passenger": {
      "type": "boolean",
      "default": true,
      "description": "是否渲染乘客模型。"
    },
    "passenger_scale": {
      "$ref": "../../base/vector_3d.schema.json",
      "default": [1, 1, 1],
      "description": "乘客模型的缩放比例。"
    },
    "views": {
      "$ref": "view_attr.schema.json",
      "default": {
        "enable_first_person": true,
        "first_person_hud": [],
        "first_person_offset": 0.0,
        "enable_third_person": true,
        "third_person_hud": [],
        "third_person_offset": 0.75,
        "follow_vehicle": true,
        "focus_on_center": true,
        "distance_scale": 1.1
      },
      "description": "视角属性设置。"
    },
    "view_inputs": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "视角切换输入信号键列表。"
    },
    "allow_use_items": {
      "type": "boolean",
      "default": false,
      "description": "是否允许乘客使用物品（如武器、工具）。"
    },
    "sounds": {
      "type": "object",
      "properties": {
        "on_destroyed": {
          "$ref": "../../base/sound_event.schema.json",
          "description": "子系统被摧毁时的音效事件。",
          "default": {
            "sound_id": "machine_max:empty_sound",
            "range": 16
          }
        },
        "on_activate": {
          "$ref": "../../base/sound_event.schema.json",
          "description": "子系统被激活时的音效事件。",
          "default": {
            "sound_id": "machine_max:empty_sound",
            "range": 16
          }
        }
      },
      "additionalProperties": false,
      "description": "子系统基本音效配置。"
    }
  },
  "required": ["type"],
  "additionalProperties": false,
  "examples": [
    {
      "type": "machine_max:seat"
    },
    {
      "type": "machine_max:seat",
      "basic_durability": 30.0,
      "block_damage": true,
      "render_passenger": true,
      "views": {
        "enable_first_person": true,
        "first_person_hud": ["machine_max:hud/driver"],
        "first_person_offset": [0.0, 0.2, 0.0],
        "enable_third_person": true,
        "third_person_hud": ["machine_max:hud/vehicle"],
        "third_person_offset": [0.0, 0.8, 0.0],
        "follow_vehicle": true,
        "focus_on_center": false,
        "distance_scale": 1.2,
        "min_pitch": -30,
        "max_pitch": 60,
        "yaw_limit": 120
      },
      "view_inputs": ["view_switch"],
      "allow_use_items": true
    }
  ]
}