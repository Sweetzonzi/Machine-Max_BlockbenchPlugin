{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/subsystem/dynamic/motorbike_controller_dynamic_attr.json",
  "title": "摩托车控制器子系统动态属性",
  "description": "车辆控制器的动态属性，定义信号输出目标和控制关系。",
  "properties": {
    "type": {
      "type": "string",
      "const": "machine_max:motorbike_controller",
      "description": "子系统类型，必须为'machine_max:motorbike_controller'。"
    },
    "definition": {
      "type": "string",
      "description": "子系统型号的资源地址，指向对应的子系统静态属性定义文件。"
    },
    "control_outputs": {
      "$ref": "../base/signal_targets.json",
      "description": "统一控制信号输出频道及目标。引擎/电动机/变速箱/车轮等受控子系统均通过此通道进行握手和信号传输。"
    },
    "speed_outputs": {
      "$ref": "../base/signal_targets.json",
      "default": { "vehicle_speed": ["subpart", "vehicle"] },
      "description": "移动速度信号输出频道及目标。可选，默认将移动速度(m/s)发至部件和载具的vehicle_speed频道。"
    },
    "throttle_outputs": {
      "$ref": "../base/signal_targets.json",
      "default": { "throttle": ["subpart", "vehicle"] },
      "description": "油门信号输出频道及目标。可选，默认将油门[0,1]发至部件和载具的throttle频道。"
    },
    "brake_outputs": {
      "$ref": "../base/signal_targets.json",
      "default": { "brake": ["subpart", "vehicle"] },
      "description": "制动信号输出频道及目标。可选，默认将制动程度[0,1]发至部件和载具的brake频道。"
    },
    "steering_outputs": {
      "$ref": "../base/signal_targets.json",
      "default": { "steering": ["subpart", "vehicle"] },
      "description": "转向角度信号输出频道及目标。可选，默认将转向程度[-1,1]发至部件和载具的steering频道。"
    },
    "handbrake_outputs": {
      "$ref": "../base/signal_targets.json",
      "default": { "handbrake": ["subpart", "vehicle"] },
      "description": "手刹器开关信号输出频道及目标。可选，默认将手刹程度[0,1]发至部件和载具的handbrake频道。"
    }
  },
  "required": ["type", "definition", "control_outputs"],
  "examples": [
    {
      "type": "machine_max:motorbike_controller",
      "definition": "machine_max:r700_motorbike_controller",
      "control_outputs": {
        "car_control": [
          "subsystem.machine_max.engine",
          "subsystem.machine_max.front_wheel_driver",
          "subsystem.machine_max.back_wheel_driver",
          "subsystem.machine_max.gearbox"
        ]
      }
    }
  ]
}
