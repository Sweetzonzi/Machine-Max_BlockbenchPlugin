{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/subsystem/dynamic/lighting_dynamic_attr.json",
  "title": "照明子系统动态属性",
  "description": "照明子系统实例属性，指定光源型号与模型定位器。",
  "properties": {
    "type": {
      "type": "string",
      "const": "machine_max:lighting",
      "description": "子系统类型，必须为'machine_max:lighting'。"
    },
    "definition": {
      "type": "string",
      "description": "子系统型号的资源地址，指向对应的照明子系统静态属性定义文件。"
    },
    "locator": {
      "type": "string",
      "description": "光源定位器名称。渲染时使用该定位器的位置和朝向。"
    }
  },
  "required": ["type", "definition", "locator"],
  "additionalProperties": false,
  "examples": [
    {
      "type": "machine_max:lighting",
      "definition": "machine_max:headlight_white",
      "locator": "Headlight_L"
    }
  ]
}
