{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/subsystem/static/gearbox_static_attr.json",
  "title": "变速箱子系统静态属性",
  "description": "变速箱的静态属性，包括减速比、换挡时间等。",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema引用路径，用于编辑器智能提示和验证",
      "default": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json"
    },
    "type": {
      "type": "string",
      "const": "machine_max:gearbox",
      "description": "子系统类型，必须为'machine_max:gearbox'。"
    },
    "basic_durability": {
      "type": "number",
      "minimum": 0,
      "default": 20.0,
      "description": "子系统基础耐久度，降至0时会瘫痪，修复至30%耐久度时恢复功能。"
    },
    "pass_damage": {
      "type": "boolean",
      "default": true,
      "description": "是否传递伤害至子系统持有者。若为true，子系统受到的伤害会传递给零件。"
    },
    "limit_damage": {
      "type": "boolean",
      "default": false,
      "description": "是否限制伤害传递值至子系统剩余耐久度。例如40伤害，子系统剩余耐久度为20，则只会传递20伤害给持有者。"
    },
    "hidden": {
      "type": "boolean",
      "default": false,
      "description": "是否隐藏子系统在HUD等处的显示，常用于纯粹提供模型部位损坏差分的无功能子系统"
    },
    "final_ratio": {
      "type": "number",
      "default": 10.0,
      "description": "最终减速比，用于整体缩放减速比。"
    },
    "ratios": {
      "type": "array",
      "items": { "type": "number" },
      "default": [-3.5, 3.5, 2.5, 1.7, 1.4, 1.1],
      "description": "减速比列表，升序排列。负数为倒挡，正数为前进挡。"
    },
    "switch_time": {
      "type": "number",
      "minimum": 0,
      "default": 0.3,
      "description": "换挡时间，单位秒。"
    },
    "control_inputs": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["car_control"],
      "description": "换挡控制信号键列表，指定选用的减速比。"
    },
    "sounds": {
      "type": "object",
      "properties": {
        "on_destroyed": {
          "$ref": "../../base/sound_event.schema.json",
          "description": "子系统被摧毁时的音效事件。",
          "default": {
            "sound_id": "machine_max:empty_sound",
            "range": 16
          }
        },
        "on_activate": {
          "$ref": "../../base/sound_event.schema.json",
          "description": "子系统被激活时的音效事件。",
          "default": {
            "sound_id": "machine_max:empty_sound",
            "range": 16
          }
        },
        "clutch_in": {
          "$ref": "../../base/sound_event.schema.json",
          "description": "离合踩下时的音效事件。",
          "default": {
            "sound_id": "machine_max:subsystem.gearbox.clutch_in",
            "range": 16
          }
        },
        "clutch_out": {
          "$ref": "../../base/sound_event.schema.json",
          "description": "离合松开时的音效事件。",
          "default": {
            "sound_id": "machine_max:subsystem.gearbox.clutch_out",
            "range": 16
          }
        },
        "gear_up": {
          "$ref": "../../base/sound_event.schema.json",
          "description": "升挡时的音效事件。",
          "default": {
            "sound_id": "machine_max:subsystem.gearbox.up.light",
            "range": 16
          }
        },
        "gear_down": {
          "$ref": "../../base/sound_event.schema.json",
          "description": "降挡时的音效事件。",
          "default": {
            "sound_id": "machine_max:subsystem.gearbox.down.light",
            "range": 16
          }
        }
      },
      "additionalProperties": false,
      "description": "变速箱操作音效配置。"
    }
  },
  "required": ["type"],
  "additionalProperties": false,
  "examples": [
    {
      "type": "machine_max:gearbox",
      "basic_durability": 60.0,
      "final_ratio": 12.0,
      "ratios": [-4.0, 3.8, 2.8, 2.0, 1.5, 1.2, 0.9],
      "switch_time": 0.4
    },
    {
      "type": "machine_max:gearbox",
      "basic_durability": 40.0,
      "final_ratio": 8.0,
      "ratios": [-3.0, 2.5, 1.8, 1.2, 0.8],
      "switch_time": 0.2,
      "sounds": {
        "clutch_in": {
          "sound_id": "minecraft:block.iron_trapdoor.close",
          "range": 8
        },
        "clutch_out": {
          "sound_id": "minecraft:block.iron_trapdoor.open",
          "range": 8
        },
        "gear_up": {
          "sound_id": "minecraft:entity.arrow.hit_player",
          "range": 12
        },
        "gear_down": {
          "sound_id": "minecraft:entity.arrow.hit",
          "range": 12
        }
      }
    }
  ]
}