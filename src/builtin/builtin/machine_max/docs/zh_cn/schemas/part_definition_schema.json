{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/part_definition_schema.json",
  "title": "部件定义",
  "description": "MachineMax载具部件的完整定义文件，这是创建自定义载具部件的顶层配置",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema引用路径，用于编辑器智能提示和验证",
      "default": "../../docs/zh_cn/schemas/part_definition_schema.json"
    },
    "icon": {
      "$ref": "base/resource_location.schema.json",
      "description": "部件图标路径，用于UI显示。若留空会使用紫黑缺省图标作为图标",
      "default": "minecraft:missingno"
    },
    "vehicle_durability_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1.0,
      "default": 0.8,
      "description": "载具耐久贡献系数，部件耐久度按此比例贡献给载具总耐久度。例如0.8表示部件的80%耐久度贡献给载具"
    },
    "vehicle_damage_rate": {
      "type": "number",
      "minimum": 0,
      "default": 1.0,
      "description": "常态载具伤害传导系数，部件受到伤害时按此比例传导给载具。例如1.0表示100%伤害传导"
    },
    "vehicle_damage_rate_destroyed": {
      "type": "number",
      "minimum": 0,
      "default": 0.1,
      "description": "部件被摧毁后的载具伤害传导系数，部件被摧毁后受到伤害时按此比例传导给载具。通常设置较低以防止鞭尸"
    },
    "functional_threshold": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.3,
      "description": "部件功能阈值。当组装进度达到该值后，子系统可工作，且线框组装渲染可自动关闭。"
    },
    "share_durability": {
      "type": "boolean",
      "default": true,
      "description": "部件内零件是否共享耐久度。如果为true，所有子部件共享同一耐久度池；如果为false，每个子部件有独立耐久度"
    },
    "max_stack_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 64,
      "default": 1,
      "description": "部件物品的最大堆叠数量。决定此部件在物品栏中可以堆叠多少个。默认值为1（不可堆叠）"
    },
    "variants": {
      "oneOf": [
        {
          "$ref": "part/variant_attr.schema.json",
          "description": "单一变体定义，使用默认变体名（\"default\"）"
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "part/variant_attr.schema.json"
          },
          "minProperties": 1,
          "description": "多变体定义，键为变体名称（如\"red\"、\"blue\"、\"camouflage\"等），值为变体配置"
        }
      ],
      "description": "部件变体列表，常用作区分左右对称的部件如轮胎或手臂，支持单一变体（默认）或多个变体配置。每个变体可以有不同的外观和特性"
    }
  },
  "additionalProperties": false,
  "required": ["variants"],
  "examples": [
    {
      "$schema": "../../docs/zh_cn/schemas/part_definition_schema.json",
      "icon": "machine_max:textures/icon/ae86_chassis_all_terrain_icon.png",
      "vehicle_durability_rate": 1.0,
      "vehicle_damage_rate": 1.0,
      "vehicle_damage_rate_destroyed": 0.1,
      "functional_threshold": 0.6,
      "share_durability": true,
      "variants": {
        "models": "machine_max:ae86_chassis_all_terrain.geo",
        "textures": [
          "machine_max:textures/part/ae86_all_terrain_1.png",
          "machine_max:textures/part/ae86_all_terrain_2.png"
        ],
        "animations": "machine_max:ae86",
        "tags": [],
        "sub_parts": {
          "ae86_chassis_all_terrain": {
            "durability": 550.0,
            "mass": 1200.0,
            "hit_boxes": {
              "mmCollision_Box_Chassis": {
                "name": "chassis",
                "type": "box",
                "thickness": 10
              }
            }
          }
        }
      }
    },
    {
      "$schema": "../../docs/zh_cn/schemas/part_definition_schema.json",
      "icon": "machine_max:textures/icon/car_chassis_icon.png",
      "vehicle_durability_rate": 0.9,
      "variants": {
        "red": {
          "models": "machine_max:car_chassis.geo",
          "textures": ["machine_max:textures/part/car_chassis_red.png"],
          "sub_parts": {
            "chassis": {
              "durability": 400.0,
              "mass": 800.0,
              "hit_boxes": {
                "collision_box": {
                  "type": "box",
                  "thickness": 8
                }
              }
            }
          }
        },
        "blue": {
          "models": "machine_max:car_chassis.geo",
          "textures": ["machine_max:textures/part/car_chassis_blue.png"],
          "sub_parts": {
            "chassis": {
              "durability": 400.0,
              "mass": 800.0,
              "hit_boxes": {
                "collision_box": {
                  "type": "box",
                  "thickness": 8
                }
              }
            }
          }
        }
      }
    }
  ]
}
