{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/subsystem/subsystem_static_attr.json",
  "title": "Subsystem Static Attributes",
  "description": "Top-level architecture for subsystem static attributes, dispatched to specific subsystem types based on the type field.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "machine_max:basic",
        "machine_max:car_controller",
        "machine_max:engine",
        "machine_max:gearbox",
        "machine_max:item_storage",
        "machine_max:motor",
        "machine_max:motor_controller",
        "machine_max:seat",
        "machine_max:transmission",
        "machine_max:wheel_driver",
        "machine_max:lighting",
        "machine_max:turret_driver",
        "machine_max:weapon_controller"
      ],
      "description": "Subsystem type, determines which specific subsystem schema to use."
    }
  },
  "additionalProperties": true,
  "required": [
    "type"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:car_controller"
          }
        }
      },
      "then": {
        "$ref": "static/car_controller_static_attr.schema.json"
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:engine"
          }
        }
      },
      "then": {
        "$ref": "static/engine_static_attr.schema.json"
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:gearbox"
          }
        }
      },
      "then": {
        "$ref": "static/gearbox_static_attr.schema.json"
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:item_storage"
          }
        }
      },
      "then": {
        "$ref": "static/item_storage_static_attr.schema.json"
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:motor"
          }
        }
      },
      "then": {
        "$ref": "static/motor_static_attr.schema.json"
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:motor_controller"
          }
        }
      },
      "then": {
        "$ref": "static/motorbike_controller_static_attr.schema.json"
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:seat"
          }
        }
      },
      "then": {
        "$ref": "static/seat_static_attr.schema.json"
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:transmission"
          }
        }
      },
      "then": {
        "$ref": "static/transmission_static_attr.schema.json"
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:wheel_driver"
          }
        }
      },
      "then": {
        "$ref": "static/wheel_driver_static_attr.schema.json"
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:lighting"
          }
        }
      },
      "then": {
        "$ref": "static/lighting_static_attr.schema.json"
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:turret_driver"
          }
        }
      },
      "then": {
        "$ref": "static/turret_driver_static_attr.schema.json"
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "machine_max:weapon_controller"
          }
        }
      },
      "then": {
        "$ref": "static/weapon_controller_static_attr.schema.json"
      }
    }
  ],
  "examples": [
    {
      "$schema": "../../docs/en_us/schemas/subsystem/subsystem_static_attr.schema.json",
      "type": "machine_max:item_storage",
      "basic_durability": 100.0,
      "rows": 6,
      "columns": 9
    },
    {
      "$schema": "../../docs/en_us/schemas/subsystem/subsystem_static_attr.schema.json",
      "type": "machine_max:engine",
      "max_power": 75000.0,
      "max_torque": 130.0,
      "red_line_rpm": 6500.0
    }
  ]
}
