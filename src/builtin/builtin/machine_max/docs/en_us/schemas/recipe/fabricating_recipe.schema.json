{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/recipe/fabricating_recipe.schema.json",
  "title": "Machine-Max Fabricating Recipe",
  "description": "Schema for machine_max:fabricating recipe.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference path for editor validation."
    },
    "type": {
      "type": "string",
      "const": "machine_max:fabricating"
    },
    "ingredients": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ingredient_count_pair"
      }
    },
    "result": {
      "$ref": "#/definitions/result_item"
    },
    "time": {
      "type": "integer",
      "minimum": 1,
      "default": 100
    },
    "description": {
      "type": "string",
      "default": ""
    }
  },
  "required": [
    "type",
    "ingredients",
    "result"
  ],
  "additionalProperties": false,
  "definitions": {
    "ingredient_selector": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^#?[a-z0-9_.-]+:[a-z0-9_./-]+$"
        },
        {
          "type": "object",
          "properties": {
            "item": { "type": "string" },
            "tag": { "type": "string" }
          },
          "anyOf": [{ "required": ["item"] }, { "required": ["tag"] }],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "neoforge:ingredient_type": { "type": "string" }
          },
          "anyOf": [{ "required": ["type"] }, { "required": ["neoforge:ingredient_type"] }],
          "additionalProperties": true
        }
      ]
    },    "ingredient_count_pair": {
      "type": "object",
      "properties": {
        "ingredient": {
          "$ref": "#/definitions/ingredient_selector"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "ingredient",
        "count"
      ],
      "additionalProperties": false
    },
    "result_item": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 99,
          "default": 1
        },
        "components": {
          "type": "object"
        }
      },
      "required": [
        "id"
      ],
      "additionalProperties": true
    }
  }
}

