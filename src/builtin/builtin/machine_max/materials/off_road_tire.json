{
  "$schema": "../docs/zh_cn/schemas/base/material_attr.schema.json",
  "friction": [1.2, 1.5, 1.0],//(可选, 默认[0.5, 0.5, 0.5])各向异性摩擦系数[侧向, 前向, 无实际效果]
  "slip_adaptation": 0.8,//(可选, 默认0.5)滑动适应性系数(0~1), 该属性可削弱打滑时的摩擦系数降低效果, 提升抓地力
  "rolling_friction": 0.2,//(可选, 默认0.2)滚动摩擦系数, 影响滚动阻力
  "spinning_friction": 0.7,
  "restitution": 0.6,//(可选, 默认0.1)弹性系数, 0为完全非弹性碰撞, 1为完全弹性碰撞, 碰撞时以此系数和相碰物体的弹性系数之积作为最终弹性系数
  "block_damage_factor": 0.05, //(可选, 默认1.0)方块破坏系数, 0为无法破坏方块, 1为造成全额伤害, 调整此系数以改变对方块的破坏能力
  "impact_modifiers": [
    {
      "operation": "multiply",
      "value": 0.1,
      "condition": {
        "type": "damage_tag",
        "id": "c:is_impact"
      }
    },
    {
      "operation": "add",
      "value": -2.0,
      "condition": {
        "type": "damage_tag",
        "id": "c:is_impact"
      }
    }
  ],
  "penetration_modifiers": [],
  "damage_modifiers": [
    {
      "operation": "multiply", // 运算符, 支持add和multiply, add则将value加到传入的数值上, multiply则乘以value
      "value": 0.1, // 修正量, 根据operation不同, 以不同的行为影响传入的数值, 这里会将撞击伤害削减至0.1倍
      "condition": {
        "type": "damage_tag", // 判断伤害是否属于某个标签
        "id": "c:is_impact" // 伤害标签注册名
      }
    },
    {
      "operation": "add", // 运算符, 支持add和multiply, add则将value加到传入的数值上, multiply则乘以value
      "value": -2.0, // 修正量, 根据operation不同, 以不同的行为影响传入的数值, 这里会将撞击伤害削减2点（不小于0）
      "condition": {
        "type": "damage_tag", // 判断伤害是否属于某个标签
        "id": "c:is_impact" // 伤害标签注册名
      }
    },
    {
      "operation": "multiply", // 运算符, 支持add和multiply, add则将value加到传入的数值上, multiply则乘以value
      "value": 0.05, // 修正量, 根据operation不同, 以不同的行为影响传入的数值, 这里会将浆果丛造成的削减至5%, 防止帧伤快速摧毁载具
      "condition": {
        "type": "damage_type",
        "id": "minecraft:sweet_berry_bush"
      }
    },
    {
      "operation": "multiply", // 运算符, 支持add和multiply, add则将value加到传入的数值上, multiply则乘以value
      "value": 0.05, // 修正量, 根据operation不同, 以不同的行为影响传入的数值, 这里会将史莱姆造成的削减至5%, 防止帧伤快速摧毁载具
      "condition": {
        "type": "entity_type",
        "id": "minecraft:slime"
      }
    },
    {
      "operation": "multiply", // 运算符, 支持add和multiply, add则将value加到传入的数值上, multiply则乘以value
      "value": 0.1, // 修正量, 根据operation不同, 以不同的行为影响传入的数值, 这里会将岩浆怪造成的削减至10%, 防止帧伤快速摧毁载具
      "condition": {
        "type": "entity_type",
        "id": "minecraft:magma_cube"
      }
    }
  ]
}