{ // 你也可以在这个目录下放置其他类型的配方，如工作台，熔炉或其他mod内容，但更推荐使用数据包
  "$schema": "../docs/zh_cn/schemas/recipe/fabricating_recipe.schema.json",
  "type": "machine_max:fabricating", // 代表此配方用于制造机与手动部件组装，当配方名和某个部件的注册名匹配时，将自动成为它的手动组装配方（仅零件可手动组装）
  "ingredients": [ // 配方原料列表。手动组装按result.count等比例ceil消耗；手动拆除按result.count等比例floor返还（floor为0的条目仍保留在材料对列表中）
    {
      "ingredient": { // 原料的类型
        "item": "machine_max:structural_component_1" 
      },
      "count": 8 // 原料的数量，制造或组装时会搜索整个背包的库存来消耗，因此可大于64。
    },
    {
      "ingredient": {
        "item": "machine_max:power_component_1" 
      },
      "count": 2
    },
    {
      "ingredient": {
        "item": "machine_max:electronic_component_1"
      },
      "count": 2
    },
    {
      "ingredient": {
        "item": "machine_max:mechanic_component_1"
      },
      "count": 1
    }
  ],
  "result": { // 产物控制制造机产出与数量。手动组装/拆除的材料折算也会参考该count
    "id": "machine_max:part", // 产物的id，即制作出的物品的注册名
    "count": 1, // 产物的数量，不应大于产物的可堆叠数量
    "components": { // (可选) 产物额外附带的数据组件，在这里用于控制具体造出了什么部件
      "machine_max:part_type": "machine_max:ae86_chassis" // 组件类型和组件内容，在组件内容填入部件的注册名以控制产出什么部件
    }
  },
  "time": 60 // 手动组装或制造机的制作时间，单位为tick，1秒=20tick
}

