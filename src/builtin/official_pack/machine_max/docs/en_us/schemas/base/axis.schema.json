{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/base/axis.json",
  "title": "Axis Direction",
  "description": "Represents the axis direction in 3D space, used to define the normal direction of connection points.",
  "type": "string",
  "enum": ["xp", "xn", "yp", "yn", "zp", "zn"],
  "default": "yp",
  "examples": ["yp", "xn", "zp"],
  "description_map": {
    "xp": "Positive X-axis direction",
    "xn": "Negative X-axis direction",
    "yp": "Positive Y-axis direction",
    "yn": "Negative Y-axis direction",
    "zp": "Positive Z-axis direction",
    "zn": "Negative Z-axis direction"
  }
}