{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/base/vector_3d.json",
  "title": "3D Vector",
  "description": "Represents a vector in 3D space",
  "type": "array",
  "items": {
    "type": "number"
  },
  "minItems": 3,
  "maxItems": 3,
  "default": [0.5, 0.5, 0.5],
  "examples": [
    [0.5, 0.5, 0.5],
    [1.0, 0.0, 0.0]
  ]
}