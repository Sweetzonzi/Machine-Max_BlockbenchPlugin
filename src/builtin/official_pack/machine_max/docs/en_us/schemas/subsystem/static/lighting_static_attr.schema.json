{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/subsystem/static/lighting_static_attr.json",
  "title": "Lighting Subsystem Static Attributes",
  "description": "Lighting subsystem definition attributes for client-side volumetric light effects.",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference path for editor validation.",
      "default": "../../docs/en_us/schemas/subsystem/subsystem_static_attr.schema.json"
    },
    "type": {
      "type": "string",
      "const": "machine_max:lighting",
      "description": "Subsystem type. Must be 'machine_max:lighting'."
    },
    "basic_durability": {
      "type": "number",
      "minimum": 0,
      "default": 20.0,
      "description": "Base subsystem durability."
    },
    "pass_damage": {
      "type": "boolean",
      "default": true,
      "description": "Whether damage is passed to the owning sub-part."
    },
    "limit_damage": {
      "type": "boolean",
      "default": false,
      "description": "Whether passed damage is limited by remaining subsystem durability."
    },
    "hidden": {
      "type": "boolean",
      "default": false,
      "description": "Whether this subsystem is hidden from HUD displays."
    },
    "light_type": {
      "type": "string",
      "enum": ["beam", "point"],
      "default": "beam",
      "description": "Light type: beam for directional beams, point for omnidirectional lights."
    },
    "range": {
      "type": "number",
      "minimum": 0,
      "default": 16,
      "description": "Volumetric light render range."
    },
    "color": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0, "maximum": 255 },
      "minItems": 3,
      "maxItems": 3,
      "default": [255, 255, 255],
      "description": "RGB color, each channel from 0 to 255."
    },
    "intensity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 1,
      "description": "Volumetric light intensity."
    },
    "beam_angle": {
      "type": "number",
      "minimum": 0,
      "maximum": 179,
      "default": 24,
      "description": "Full directional beam cone angle in degrees."
    }
  },
  "required": ["type"],
  "additionalProperties": false,
  "examples": [
    {
      "type": "machine_max:lighting",
      "basic_durability": 20,
      "hidden": true,
      "light_type": "beam",
      "range": 16,
      "color": [255, 245, 210],
      "intensity": 0.75,
      "beam_angle": 24
    }
  ]
}
