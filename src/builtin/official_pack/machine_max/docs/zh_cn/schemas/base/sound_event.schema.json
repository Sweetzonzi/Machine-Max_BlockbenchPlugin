{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/base/sound_event.json",
  "title": "音效事件",
  "description": "Minecraft音效事件配置，包含音效ID和范围。",
  "type": "object",
  "properties": {
    "sound_id": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+:[a-z0-9_./-]+$",
      "description": "音效事件资源位置标识符，格式为'命名空间:路径'",
      "default": "machine_max:subsystem.gearbox.clutch_in"
    },
    "range": {
      "type": "number",
      "minimum": 0,
      "description": "音效事件的固定范围，单位：方块",
      "default": 16
    }
  },
  "required": ["sound_id"],
  "additionalProperties": false,
  "examples": [
    {
      "sound_id": "machine_max:subsystem.gearbox.clutch_in",
      "range": 16
    },
    {
      "sound_id": "minecraft:entity.cow.ambient",
      "range": 8
    }
  ]
}