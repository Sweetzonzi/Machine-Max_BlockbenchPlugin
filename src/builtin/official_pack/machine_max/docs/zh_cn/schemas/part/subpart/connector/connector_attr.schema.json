{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/connector/connector_attr.schema.json",
  "title": "连接点属性",
  "description": "定义部件连接点的属性，包括位置、定义ID、信号传输等。连接点用于部件之间的物理连接和信号传递。静态属性通过definition字段引用预定义的连接点类型。",
  "type": "object",
  "properties": {
    "locator": {
      "type": "string",
      "description": "连接点对应的Locator名称，会寻找名称匹配的Locator，以其位置与姿态作为连接点的位置和姿态。"
    },
    "definition": {
      "type": "string",
      "description": "连接点定义ID，引用预定义的连接点静态属性。例如：\"machine_max:simple_connector\"。"
    },
    "power_target": {
      "type": "string",
      "description": "对侧连接器传入的机械能在本零件内的接收目标（子系统名或连接点名）。设置后该连接点可作为机械能传输通道，将对侧传入的机械能转发至本零件内的目标。例如：\"subsystem.machine_max.engine\"。"
    },
    "overwrite": {
      "type": "object",
      "description": "连接点属性覆写。可按需覆写definition指向的静态连接点属性。",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Simple", "simple", "advanced", "Advanced"],
          "description": "连接点类型覆写。"
        },
        "direction": {
          "$ref": "../../../base/axis.schema.json",
          "description": "连接点法线方向覆写。"
        },
        "integrity": {
          "type": "number",
          "minimum": 0.0,
          "description": "结构完整性覆写。"
        },
        "impact_absorption": {
          "type": "number",
          "minimum": 0.0,
          "description": "冲击转结构损耗比例覆写。"
        },
        "impact_reduction": {
          "type": "number",
          "minimum": 0.0,
          "description": "冲击减免值覆写。"
        },
        "impact_multiplier": {
          "type": "number",
          "minimum": 0.0,
          "description": "冲击倍率覆写。"
        },
        "collide_between_parts": {
          "type": "boolean",
          "description": "是否允许部件间碰撞覆写。"
        },
        "required_tags": {
          "type": "array",
          "items": { "$ref": "../../../base/resource_location.schema.json" },
          "description": "必需标签覆写。"
        },
        "acceptable_tags": {
          "type": "array",
          "items": { "$ref": "../../../base/resource_location.schema.json" },
          "description": "可接受标签覆写。"
        },
        "forbidden_tags": {
          "type": "array",
          "items": { "$ref": "../../../base/resource_location.schema.json" },
          "description": "禁止标签覆写。"
        },
        "joint_attrs": {
          "type": "object",
          "additionalProperties": { "$ref": "joint_attr.schema.json" },
          "description": "关节属性覆写。"
        }
      },
      "additionalProperties": false
    },
    "signal_translations": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "default": {},
      "description": "从对侧连接点接收到的信号频道转译规则，例如：{\"channel_a\": \"channel_c\"}表示将channel_a信号转译为channel_c。"
    },
    "signal_targets": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      },
      "default": {},
      "description": "连接点在本零件内的控制信号传输目标，键为信号频道，值为目标列表（子系统/连接点名/part/vehicle）。例如：{\"move_control\": [\"car_controller\", \"engine\"]}。"
    },
    "internal": {
      "type": "boolean",
      "default": false,
      "description": "是否为部件内部连接点。为true时仅用于同一Part内部自动连接，不参与对外拼装。"
    }
  },
  "required": ["locator", "definition"],
  "additionalProperties": false,
  "examples": [
    {
      "locator": "Hull",
      "definition": "machine_max:simple_connector"
    },
    {
      "locator": "LeftFrontWheel",
      "definition": "machine_max:advanced_wheel_connector",
      "overwrite": {
        "type": "Advanced",
        "direction": "y+",
        "integrity": 32.0,
        "impact_absorption": 0.15,
        "impact_reduction": 3.0,
        "impact_multiplier": 0.8,
        "collide_between_parts": false,
        "required_tags": ["machine_max:left"],
        "acceptable_tags": ["machine_max:wheel", "machine_max:suspension"],
        "forbidden_tags": ["machine_max:broken_only"],
        "joint_attrs": {
          "y": {
            "lower_limit": -0.2,
            "upper_limit": 0.25,
            "stiffness": 30000,
            "damping": 1600
          },
          "yr": {
            "lower_limit": -35.0,
            "upper_limit": 35.0,
            "stiffness": 4500,
            "damping": 24
          }
        }
      },
      "signal_translations": {
        "steering": "wheel_control"
      },
      "signal_targets": {
        "wheel_control": ["wheel_driver", "subpart"],
        "abs_request": ["vehicle"]
      },
      "internal": true
    }
  ]
}
