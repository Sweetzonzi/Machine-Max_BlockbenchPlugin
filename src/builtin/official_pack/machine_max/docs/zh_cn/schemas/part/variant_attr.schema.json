{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/part/variant_attr.json",
  "title": "部件变体属性",
  "description": "定义载具部件的一个变体（Variant），包含该变体的外观、模型、子部件等配置。支持多状态（state）映射。",
  "type": "object",
  "properties": {
    "tags": {
      "type": "array",
      "items": {
        "$ref": "../base/resource_location.schema.json"
      },
      "default": [],
      "description": "部件标签列表，用于连接点匹配和功能分类"
    },
    "model": {
      "$ref": "../base/resource_location.schema.json",
      "description": "模型路径，无视内层文件夹架构，例如machine_max:ae86_chassis.geo会在所有内容包的models/machine_max/part的所有子目录中中寻找ae86_chassis.geo.json"
    },
    "textures": {
      "oneOf": [
        {
          "$ref": "../base/resource_location.schema.json",
          "default": "minecraft:missingno",
          "description": "单一纹理，例如\"machine_max:textures/part/ae86/ae86_armor.png\"会将内容包相应路径的图像作为部件的\"default\"纹理"
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "../base/resource_location.schema.json"
          },
          "default": {
            "default": "minecraft:missingno"
          },
          "description": "名称到纹理列表的映射，键为纹理名称，值为纹理路径。例如：\"textures\": {\n            \"example_2\": \"machine_max:textures/part/texture_2.png\"\n          }则会将相应路径的图像作为部件的\"example_2\"纹理。"
        }
      ],
      "default": {},
      "description": "纹理路径配置。"
    },
    "animations": {
      "$ref": "../base/resource_location.schema.json",
      "default": {},
      "description": "动画路径，无视内层文件夹架构，例如machine_max:ae86会在所有内容包的animations/machine_max/part/ae86中的所有动画json作为模型的可用动画"
    },
    "sub_parts": {
      "oneOf": [
        {
          "$ref": "subpart/sub_part_attr.schema.json",
          "description": "单一零件定义，使用默认零件名（\"sub_part.machine_max.main\"）"
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "subpart/sub_part_attr.schema.json"
          },
          "minProperties": 1,
          "description": "多零件定义，键为零件名称，值为零件配置"
        }
      ],
      "description": "子部件（零件）定义，支持单一零件（简写）或多个零件（键值对）两种写法。这是部件运动的最小单元，部件的每个可动部分都应当是一个子部件"
    }
  },
  "additionalProperties": false,
  "required": ["model", "sub_parts"],
  "examples": [
    {
      "model": "machine_max:ae86_chassis_all_terrain.geo",
      "textures": [
        "machine_max:textures/part/ae86_all_terrain_1.png",
        "machine_max:textures/part/ae86_all_terrain_2.png"
      ],
      "animations": "machine_max:ae86",
      "tags": [],
      "sub_parts": {
        "ae86_chassis_all_terrain": {
          "durability": 550.0,
          "mass": 1200.0,
          "hit_boxes": {
            "mmCollision_Box_Chassis": {
              "name": "chassis",
              "type": "box",
              "thickness": 10
            }
          }
        }
      }
    },
    {
      "model": {
        "default": "machine_max:tank_turret_normal.geo",
        "broken": "machine_max:tank_turret_damaged.geo"
      },
      "textures": {
        "default": [
          "machine_max:textures/part/tank_turret_1.png",
          "machine_max:textures/part/tank_turret_2.png"
        ],
        "broken": [
          "machine_max:textures/part/tank_turret_damaged_1.png",
          "machine_max:textures/part/tank_turret_damaged_2.png"
        ]
      },
      "animations": {
        "default": "machine_max:tank_turret_rotation",
        "broken": "machine_max:tank_turret_broken"
      },
      "tags": ["machine_max:turret", "machine_max:rotatable"],
      "sub_parts": {
        "turret_base": {
          "durability": 300.0,
          "mass": 800.0,
          "hit_boxes": {
            "mmCollision_Turret": {
              "name": "turret",
              "type": "cylinder",
              "thickness": 50
            }
          }
        }
      }
    }
  ]
}
