{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/subsystem/static/basic_static_attr.json",
  "title": "基础子系统静态属性",
  "description": "无实际功能的基础子系统，可被实例化，作为无功能但可向载具传导伤害的子系统，例如载具的可破坏弱点。",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema引用路径，用于编辑器智能提示和验证",
      "default": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json"
    },
    "type": {
      "type": "string",
      "const": "machine_max:basic",
      "description": "子系统类型，必须为'machine_max:basic'。"
    },
    "basic_durability": {
      "type": "number",
      "minimum": 0,
      "default": 20.0,
      "description": "子系统基础耐久度，降至0时会瘫痪，修复至30%耐久度时恢复功能。"
    },
    "pass_damage": {
      "type": "boolean",
      "default": true,
      "description": "是否传递伤害至子系统持有者。若为true，子系统受到的伤害会传递给零件。"
    },
    "limit_damage": {
      "type": "boolean",
      "default": false,
      "description": "是否限制伤害传递值至子系统剩余耐久度。例如40伤害，子系统剩余耐久度为20，则只会传递20伤害给持有者。"
    },
    "hidden": {
      "type": "boolean",
      "default": false,
      "description": "是否隐藏子系统在HUD等处的显示，常用于纯粹提供模型部位损坏差分的无功能子系统"
    },
    "sounds": {
      "type": "object",
      "properties": {
        "on_destroyed": {
          "$ref": "../../base/sound_event.schema.json",
          "description": "子系统被摧毁时的音效事件。",
          "default": {
            "sound_id": "machine_max:empty_sound",
            "range": 16
          }
        },
        "on_activate": {
          "$ref": "../../base/sound_event.schema.json",
          "description": "子系统被激活时的音效事件。",
          "default": {
            "sound_id": "machine_max:empty_sound",
            "range": 16
          }
        }
      },
      "additionalProperties": false,
      "description": "子系统基本音效配置。"
    }
  },
  "required": ["type"],
  "additionalProperties": false,
  "examples": [
    {
      "type": "machine_max:basic",
      "description": "最简示例 - 仅包含必须字段"
    },
    {
      "type": "machine_max:basic",
      "basic_durability": 30.0,
      "pass_damage": false,
      "description": "高级示例 - 禁用伤害传递，可用于车窗玻璃"
    },
    {
      "type": "machine_max:basic",
      "basic_durability": 50.0,
      "pass_damage": true,
      "limit_damage": true,
      "description": "完整示例 - 包含所有可选字段"
    }
  ]
}