{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/subsystem/dynamic/engine_dynamic_attr.json",
  "title": "引擎子系统动态属性",
  "description": "引擎的动态属性，定义功率输出目标和转速信号输出。",
  "properties": {
    "type": {
      "type": "string",
      "const": "machine_max:engine",
      "description": "子系统类型，必须为'machine_max:engine'。"
    },
    "definition": {
      "type": "string",
      "description": "子系统型号的资源地址，指向对应的子系统静态属性定义文件。"
    },
    "power_output": {
      "type": "string",
      "description": "功率输出目标，可填写任意本部件内其他子系统名称、部件连接点名称，或'part'，或'vehicle'。"
    },
    "speed_outputs": {
      "$ref": "../base/signal_targets.json",
      "default": {},
      "description": "引擎转速信号输出频道及目标。可选，默认将引擎转速(rad/s)发至部件和载具的engine_speed频道。"
    }
  },
  "required": ["type", "definition", "power_output"],
  "examples": [
    {
      "type": "machine_max:engine",
      "definition": "machine_max:ae86at_engine",
      "power_output": "gearbox",
      "speed_outputs": { "engine_speed": ["part", "vehicle"] }
    }
  ]
}