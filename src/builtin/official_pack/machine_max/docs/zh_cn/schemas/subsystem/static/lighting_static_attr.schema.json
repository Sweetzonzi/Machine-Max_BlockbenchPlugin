{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://machine_max.io/schemas/subsystem/static/lighting_static_attr.json",
  "title": "照明子系统静态属性",
  "description": "照明子系统型号属性，用于定义客户端体积光效果。",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema引用路径，用于编辑器智能提示和验证",
      "default": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json"
    },
    "type": {
      "type": "string",
      "const": "machine_max:lighting",
      "description": "子系统类型，必须为'machine_max:lighting'。"
    },
    "basic_durability": {
      "type": "number",
      "minimum": 0,
      "default": 20.0,
      "description": "子系统基础耐久度，降至0时会瘫痪，修复至30%耐久度时恢复功能。"
    },
    "pass_damage": {
      "type": "boolean",
      "default": true,
      "description": "是否传递伤害至子系统持有者。"
    },
    "limit_damage": {
      "type": "boolean",
      "default": false,
      "description": "是否限制伤害传递值至子系统剩余耐久度。"
    },
    "hidden": {
      "type": "boolean",
      "default": false,
      "description": "是否隐藏子系统在HUD等处的显示。"
    },
    "light_type": {
      "type": "string",
      "enum": ["beam", "point"],
      "default": "beam",
      "description": "光源类型：beam为定向光束，point为点光源。"
    },
    "range": {
      "type": "number",
      "minimum": 0,
      "default": 16,
      "description": "体积光渲染范围。"
    },
    "color": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0, "maximum": 255 },
      "minItems": 3,
      "maxItems": 3,
      "default": [255, 255, 255],
      "description": "RGB颜色，取值范围0-255。"
    },
    "intensity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 1,
      "description": "体积光强度。"
    },
    "beam_angle": {
      "type": "number",
      "minimum": 0,
      "maximum": 179,
      "default": 24,
      "description": "定向光束完整锥角，单位为度。"
    }
  },
  "required": ["type"],
  "additionalProperties": false,
  "examples": [
    {
      "type": "machine_max:lighting",
      "basic_durability": 20,
      "hidden": true,
      "light_type": "beam",
      "range": 16,
      "color": [255, 245, 210],
      "intensity": 0.75,
      "beam_angle": 24
    }
  ]
}
