{
  "$schema": "../../docs/zh_cn/schemas/part_definition_schema.json",
  "icon": "machine_max:textures/icon/r700/r700_chassis_icon.png",
  "vehicle_durability_rate": 0.6,
  "vehicle_damage_rate": 1.0,
  "vehicle_damage_rate_destroyed": 0.1,
  "variants": {
    "model": "machine_max:r700_chassis.geo",
    "textures": "machine_max:textures/part/r700.png",
    "animations": "machine_max:r700",
    "tags": ["machine_max:chassis", "machine_max:r700"],
    "sub_parts": {
      "sub_part.machine_max.main": {
        "durability": 120.0,
        "mass": 87.0,
        "block_collision": "ground",
        "collision_height": 1.5,
        "hit_boxes": { //键:骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体, 以及将此骨骼下的定位器储存起来供子系统等使用
          "Collision": { //值:碰撞形状属性
            "id": "part",
            "type": "box", //碰撞形状类型, 支持box、sphere、cylinder
            "material": "machine_max:structural_steel",
            "thickness": 3 //(可选, 默认1)等效护甲厚度, 单位mm, 减免伤害并控制碰撞时的能量分配情况
          },
          "EngineCollision": { //值:碰撞形状属性
            "id": "engine",
            "type": "box", //碰撞形状类型, 支持box、sphere、cylinder
            "subsystem": "subsystem.machine_max.engine", //(可选, 默认"")子系统名称, 对此碰撞形状造成的伤害会等量地传导给此子系统, 若为空则不属于任何子系统
            "material": "machine_max:structural_steel",
            "thickness": 1 //(可选, 默认1)等效护甲厚度, 单位mm, 减免伤害并控制碰撞时的能量分配情况
          },
          "TrunkCollision": {
            "id": "trunk",
            "type": "box",
            "subsystem": "subsystem.machine_max.trunk",
            "damage_modifiers": [],
            "thickness": 1
          },
          "GloveBoxCollision": {
            "id": "trunk",
            "type": "box",
            "subsystem": "subsystem.machine_max.glove_box",
            "damage_modifiers": [],
            "thickness": 1
          },
          "FrontCaseCollision": {
            "id": "trunk",
            "type": "box",
            "subsystem": "subsystem.machine_max.front_case",
            "damage_modifiers": [],
            "thickness": 1
          }
        },
        "interact_boxes": { //交互判定区列表
          "interact.machine_max.seat": { //键:交互判定区名称
            "bone": "SeatInteract", //骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "seat_interact": ["subsystem.machine_max.driver_seat"] //将交互信号转发给驾驶座
            },
            "interact_mode": "fast" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          },
          "interact.machine_max.glove_box": {
            "bone": "GloveBoxInteract",
            "signal_targets": {
              "interact": ["subsystem.machine_max.glove_box"]
            },
            "interact_mode": "accurate"
          },
          "interact.machine_max.trunk": {
            "bone": "TrunkInteract",
            "signal_targets": {
              "interact": ["subsystem.machine_max.trunk"]
            },
            "interact_mode": "accurate"
          },
          "interact.machine_max.front_case": {
            "bone": "FrontCaseInteract",
            "signal_targets": {
              "interact": ["subsystem.machine_max.front_case"]
            },
            "interact_mode": "accurate"
          }
        },
        "subsystems": {
          "subsystem.machine_max.driver_seat": {
            "type": "machine_max:seat", //子系统类型
            "definition": "machine_max:default_seat", //子系统型号, 需要与子系统类型相匹配
            "locator": "SeatPoint", //乘坐点定位器名称, 该定位器需要位于任意零件的碰撞箱骨骼中, 乘客将被定位于此
            "move_outputs": { //(可选,默认为空)子系统移动控制输出列表
              "move_control": ["subsystem.machine_max.motorbike_controller"] //将控制信号转发给车辆控制系统
            },
            "regular_outputs": { //(可选,默认为空)子系统常规按键输出列表
              "regular_control": ["subsystem.machine_max.motorbike_controller"] //将控制信号转发给车辆控制系统
            },
            "aim_outputs": { //(可选,默认为空)子系统视角控制输出列表
              "aim_control": ["subsystem.machine_max.motorbike_controller"]
            },
            "passenger_num_outputs": {
              "occupied": ["interact.machine_max.seat"]
            }
          },
          "subsystem.machine_max.motorbike_controller": {
            "type": "machine_max:motorbike_controller", //子系统类型
            "definition": "machine_max:r700_motorbike_controller",//子系统型号, 需要与子系统类型相匹配
            "control_outputs": {
              "car_control": [
                "subsystem.machine_max.back_wheel_driver",
                "subsystem.machine_max.engine",
                "subsystem.machine_max.front_wheel_driver",
                "subsystem.machine_max.gearbox"
              ]
            },
            "gearbox_outputs": {
              "gearbox_control": ["subsystem.machine_max.gearbox"]
            }
          },
          "subsystem.machine_max.engine": {
            "type": "machine_max:engine", //电动机子系统, 低速下恒扭矩, 高速下恒功率
            "definition": "machine_max:r700_engine",//子系统型号, 需要与子系统类型相匹配
            "power_output": "subsystem.machine_max.gearbox", //功率输出目标, 可填写任意本部件内其他子系统名称、部件连接点名称, 或“part”, 或“vehicle”
            "speed_outputs": { //(可选, 默认将引擎转速(rad/s)发至部件和载具的engine_speed频道)引擎转速信号输出频道及目标
              "engine_speed": ["subpart", "vehicle"]
            }
          },
          "subsystem.machine_max.gearbox": {
            "type": "machine_max:gearbox", //变速箱子系统, 改变收到的功率信号的扭矩和转速
            "definition": "machine_max:r700_gearbox", //子系统型号, 需要与子系统类型相匹配
            "power_output": "subsystem.machine_max.back_wheel_driver", //功率输出目标, 子系统或部件连接点名
            "gear_outputs": { //(可选, 默认将当前挡位名称发至部件和载具的gear频道)挡位名称输出频道及目标
              "gear": ["subpart", "vehicle"]
            }
          },
          "subsystem.machine_max.glove_box": {
            "type": "machine_max:item_storage", //储物子系统, 互动可打开存储容器
            "definition": "machine_max:glove_box" //子系统型号, 需要与子系统类型相匹配
          },
          "subsystem.machine_max.front_case": {
            "type": "machine_max:item_storage",
            "definition": "machine_max:glove_box"
          },
          "subsystem.machine_max.trunk": {
            "type": "machine_max:item_storage",
            "definition": "machine_max:default_trunk"
          },
          "subsystem.machine_max.front_wheel_driver": {
            "type": "machine_max:wheel_driver", //轮胎驱动子系统, 驱动连接点上的部件滚动和转向
            "definition": "machine_max:r700_front_wheel_driver", //子系统型号, 需要与子系统类型相匹配
            "connector": "connector.machine_max.front_wheel" //控制的连接点名称
          },
          "subsystem.machine_max.back_wheel_driver": {
            "type": "machine_max:wheel_driver",
            "definition": "machine_max:r700_back_wheel_driver",
            "connector": "connector.machine_max.back_wheel"
          }
        },
        "connectors": {
          "connector.machine_max.front_wheel": { //连接点名称
            "locator": "front_wheel", //Locator名称, 会寻找名称匹配的Locator, 以其位置与姿态作为连接点的位置和姿态
            "definition": "machine_max:r700_front_wheel"
          },
          "connector.machine_max.back_wheel": {
            "locator": "back_wheel",
            "definition": "machine_max:r700_back_wheel"
          }
        },
        "projected_area": [2.0, 2.0, 2.32],
        "hydro_priority": 10,
        "hydrodynamics": {
          "": {
            "front_drag": [0.0, 0.3],
            "back_drag": [0.0, 0.5]
          }
        }
      }
    }
  }
}