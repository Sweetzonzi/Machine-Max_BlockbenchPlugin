{
  "$schema": "../docs/zh_cn/schemas/part_definition_schema.json",
  "icon": "machine_max:textures/icon/reinforced_container_16x16x8_icon.png",//(可选, 留空会使用紫黑格子)部件图标路径
  "vehicle_durability_rate": 0.0,//(可选, 默认0.8)载具耐久贡献系数, 部件耐久度按此比例贡献给载具总耐久度
  "vehicle_damage_rate": 0.0,//(可选, 默认1.0)常态载具伤害传导系数, 部件受到伤害时按此比例传导给载具
  "vehicle_damage_rate_destroyed": 0.0,//(可选, 默认0.1)部件被摧毁后的载具伤害传导系数, 部件被摧毁后受到伤害时按此比例传导给载具
  "variants": {//部件变体列表, 支持单值或多键值对
    "model": "machine_max:container_16x16x8.geo", //模型路径
    "textures": "machine_max:textures/part/reinforced_container_16x16x8.png",
    "animations": "machine_max:empty", //(可选, 留空则不播放动画)动画路径
    "tags": ["machine_max:storage"],
    "sub_parts": {//零件(子部件)列表
      "sub_part.machine_max.main": {//零件(子部件)名称
        "durability": 150.0,//(可选, 默认20.0)部件基础生命值, 降至0时部件的所有子系统会瘫痪
        "mass": 30.0,//零件质量(kg)
        "block_collision": "true",//(可选, 默认true)地形碰撞模式:true(与所有方块碰撞),ground(仅与低于部件最低位置的地面方块碰撞),false(不与任何方块碰撞)
        "collision_height": 0,//(可选)碰撞检测高度(m), 遭遇的障碍小于此高度时不与障碍发生碰撞(方块碰撞模式需要为ground), 默认所有障碍均碰撞
        "climb_assist": false,//(可选, 默认false)是否开启自动攀爬辅助, 开启后会在自动攀爬时提供额外的速度
        "hit_boxes": {//键:骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体, 以及将此骨骼下的定位器储存起来供子系统等使用
          "Shape": {//骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体
            "type": "box",//碰撞形状类型, 支持box、sphere、cylinder
            "material": "machine_max:structural_steel"
          }
        },
        "interact_boxes": {//交互判定区列表
          "interact.machine_max.reinforced_container_16x16x8": {//键:交互判定区名称
            "bone": "Interact",//骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "trunk_interact": ["subsystem.machine_max.reinforced_container_16x16x8"] //将交互信号转发给与车体连接的连接点
            },
            "interact_mode": "accurate" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          }
        },
        "subsystems": {//(可选)子系统配置
          "subsystem.machine_max.reinforced_container_16x16x8": {
            "type": "machine_max:item_storage",//子系统类型
            "definition": "machine_max:container_16x16x8"//子系统型号, 需要与子系统类型相匹配
          }
        },
        "connectors": {//子部件用于与其他零件连接的连接点列表
          "connector.machine_max.up": {//连接点名称
            "locator": "up",//Locator名称, 会寻找名称匹配的Locator, 以其位置与姿态作为连接点的位置和姿态
            "definition": "machine_max:fixed_up"
          },
          "connector.machine_max.down": {//连接点名称
            "locator": "down",//Locator名称, 会寻找名称匹配的Locator, 以其位置与姿态作为连接点的位置和姿态
            "definition": "machine_max:fixed_down"
          }
        }
      }
    }
  }
}