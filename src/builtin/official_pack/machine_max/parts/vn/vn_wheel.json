{
  "$schema": "../../docs/zh_cn/schemas/part_definition_schema.json",
  "icon": "machine_max:textures/icon/vn/vn_wheel_icon.png",//(可选, 留空会使用紫黑格子)部件图标路径
  "vehicle_durability_rate": 1.0,//(可选, 默认1.0)载具耐久贡献系数, 部件耐久度按此比例贡献给载具总耐久度
  "vehicle_damage_rate": 0.5,//(可选, 默认1.0)常态载具伤害传导系数, 部件受到伤害时按此比例传导给载具
  "vehicle_damage_rate_destroyed": 0.1,//(可选, 默认0.5)部件被摧毁后的载具伤害传导系数, 部件被摧毁后受到伤害时按此比例传导给载具
  "max_stack_size": 2,
  "variants": {//部件变体列表, 支持单值或多键值对
    "model": "machine_max:vn_wheel.geo", //模型路径
    "textures": "machine_max:textures/part/vn/vn.png",
    "animations": "machine_max:empty", //(可选, 留空则不播放动画)动画路径
    "tags": ["machine_max:wheel", "machine_max:vn", "machine_max:left", "machine_max:right"],//(可选)部件标签列表
    "sub_parts": {//零件(子部件)列表
      "sub_part.machine_max.main": {//零件(子部件)名称
        "durability": 100.0,//(可选, 默认20.0)部件基础生命值, 降至0时部件的所有子系统会瘫痪
        "mass": 20.0,//零件质量(kg)
        "block_collision": "ground",//(可选, 默认true)地形碰撞模式:true(与所有方块碰撞),ground(仅与低于部件最低位置的地面方块碰撞),false(不与任何方块碰撞)
        "collision_height": 1.5,//(可选)碰撞检测高度(m), 遭遇的障碍小于此高度时不与障碍发生碰撞(方块碰撞模式需要为ground), 默认所有障碍均碰撞
        "climb_assist": true,//(可选, 默认false)是否开启自动攀爬辅助, 开启后会在自动攀爬时提供额外的速度
        "hit_boxes": {//键:骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体, 以及将此骨骼下的定位器储存起来供子系统等使用
          "Collision": {//骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体
            "type": "wheel",//碰撞形状类型, 支持box、sphere、cylinder、wheel
            "material": "machine_max:off_road_tire"
          }
        },
        "connectors": {//子部件用于与其他零件连接的连接点列表
          "connector.machine_max.chassis_connection": {//连接点名称
            "locator": "chassis_connection",//Locator名称, 会寻找名称匹配的Locator, 以其位置与姿态作为连接点的位置和姿态
            "definition": "machine_max:fixed_right",
            "overwrite": {
              "integrity": 40.0,
              "impact_reduction": 3.0,
              "impact_multiplier": 0.8
            }
          }
        },
        "projected_area": [0.766, 0.11, 0.11],
        "hydrodynamics": {
          "": {
            "front_drag": [0.0, 0.35],
            "back_drag": [0.0, 0.35],
            "left_drag": [0.0, 0.35],
            "right_drag": [0.0, 0.35],
            "up_drag": [0.0, 0.35],
            "down_drag": [0.0, 0.35]
          }
        }
      }
    }
  }
}