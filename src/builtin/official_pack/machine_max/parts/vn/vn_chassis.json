{
  "$schema": "../../docs/zh_cn/schemas/part_definition_schema.json",
  "icon": "machine_max:textures/icon/vn/vn_chassis_icon.png",
  "vehicle_durability_rate": 0.6,
  "vehicle_damage_rate": 1.0,
  "vehicle_damage_rate_destroyed": 0.1,
  "variants": {
    "model": "machine_max:vn_chassis.geo",
    "textures": "machine_max:textures/part/vn/vn.png",
    "animations": "machine_max:vn",
    "tags": ["machine_max:chassis", "machine_max:vn"],
    "sub_parts": {
      "sub_part.machine_max.main": {
        "durability": 300.0,
        "mass": 150.0,
        "block_collision": "ground",
        "collision_height": 1.5,
        "hit_boxes": {
          "Collision": { //值:碰撞形状属性
            "id": "part",
            "type": "box", //碰撞形状类型, 支持box、sphere、cylinder
            "material": "machine_max:rha",
            "thickness": 3 //(可选, 默认1)等效护甲厚度, 单位mm, 减免伤害并控制碰撞时的能量分配情况
          }
        },
        "interact_boxes": {
          "interact.machine_max.seat": { //键:交互判定区名称
            "bone": "Interact", //骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "seat_interact": ["subsystem.machine_max.driver_seat"] //将交互信号转发给驾驶座
            },
            "interact_mode": "fast" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          }
        },
        "subsystems": {
          "subsystem.machine_max.driver_seat": {
            "type": "machine_max:seat", //子系统类型
            "definition": "machine_max:vn_seat", //子系统型号, 需要与子系统类型相匹配
            "locator": "seat", //乘坐点定位器名称, 该定位器需要位于任意零件的碰撞箱骨骼中, 乘客将被定位于此
            "move_outputs": { //(可选,默认为空)子系统移动控制输出列表
              "move_control": ["subsystem.machine_max.motorbike_controller"] //将控制信号转发给车辆控制系统
            },
            "regular_outputs": { //(可选,默认为空)子系统常规按键输出列表
              "regular_control": ["subsystem.machine_max.motorbike_controller"] //将控制信号转发给车辆控制系统
            },
            "aim_outputs": { //(可选,默认为空)子系统视角控制输出列表
              "aim_control": ["subsystem.machine_max.motorbike_controller"]
            },
            "passenger_num_outputs": {
              "occupied": ["interact.machine_max.seat"]
            }
          },
          "subsystem.machine_max.motorbike_controller": {
            "type": "machine_max:motorbike_controller", //子系统类型
            "definition": "machine_max:vn_motorbike_controller",//子系统型号, 需要与子系统类型相匹配
            "control_outputs": {
              "car_control": [
                "subsystem.machine_max.motor",
                "subsystem.machine_max.front_wheel_driver",
                "subsystem.machine_max.back_wheel_driver"
              ]
            }
          },
          "subsystem.machine_max.motor": {
            "type": "machine_max:motor",
            "definition": "machine_max:vn_motor",
            "power_output": "subsystem.machine_max.transmission",
            "speed_outputs": {
              "engine_speed": ["subpart", "vehicle"]
            }
          },
          "subsystem.machine_max.transmission": {
            "type": "machine_max:transmission",
            "definition": "machine_max:vn_transmission",
            "power_outputs": { //动力输出目标及减速比
              "subsystem.machine_max.back_wheel_driver": 3,
              "subsystem.machine_max.front_wheel_driver": 3
            }
          },
          "subsystem.machine_max.front_wheel_driver": {
            "type": "machine_max:wheel_driver",
            "definition": "machine_max:vn_front_wheel_driver",
            "connector": "connector.machine_max.front_wheel"
          },
          "subsystem.machine_max.back_wheel_driver": {
            "type": "machine_max:wheel_driver",
            "definition": "machine_max:vn_back_wheel_driver",
            "connector": "connector.machine_max.back_wheel"
          }
        },
        "connectors": {
          "connector.machine_max.front_wheel": { //连接点名称
            "locator": "front_wheel", //Locator名称, 会寻找名称匹配的Locator, 以其位置与姿态作为连接点的位置和姿态
            "definition": "machine_max:vn_front_wheel"
          },
          "connector.machine_max.back_wheel": {
            "locator": "back_wheel",
            "definition": "machine_max:vn_back_wheel"
          }
        },
        "projected_area": [2.0, 2.0, 2.32],
        "hydro_priority": 10,
        "hydrodynamics": {
          "": {
            "front_drag": [0.0, 0.1],
            "back_drag": [0.0, 0.2]
          }
        }
      }
    }
  }
}