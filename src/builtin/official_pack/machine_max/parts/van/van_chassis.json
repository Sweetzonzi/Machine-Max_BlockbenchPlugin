{
  "$schema": "../../docs/zh_cn/schemas/part_definition_schema.json",
  "icon": "machine_max:textures/icon/van/van_chassis_icon.png",
  "vehicle_durability_rate": 0.6,
  "vehicle_damage_rate": 1.0,
  "vehicle_damage_rate_destroyed": 0.1,
  "variants": {
    "model": "machine_max:van.geo",
    "textures": "machine_max:textures/part/van/van.png",
    "animations": "machine_max:van",
    "tags": ["machine_max:chassis", "machine_max:van", "machine_max:storage"],
    "sub_parts": {
      "sub_part.machine_max.main": {
        "start_bone": "Chassis", // (可选，默认空)起始骨骼名称，此骨骼及其包含的骨骼才会被作为零件的渲染与定义用模型
        "end_bones": ["LeftBackWheel", "RightBackWheel"], // (可选，默认空)终止骨骼列表, 此骨骼及其包含的骨骼会被排除到渲染与定义用模型之外，配合start_bone选定零件对应的骨骼范围
        "mass_center": "chassis_mass_center", //  (可选，默认取碰撞体积形心)质心位置locator名称
        "durability": 800.0,
        "mass": 500.0,
        "block_collision": "ground",
        "collision_height": 1.5,
        "hit_boxes": { //键:骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体, 以及将此骨骼下的定位器储存起来供子系统等使用
          "collision_chassis": { //值:碰撞形状属性
            "type": "box", //碰撞形状类型, 支持box、sphere、cylinder
            "material": "machine_max:structural_steel",
            "thickness": 3 //(可选, 默认1)等效护甲厚度, 单位mm, 减免伤害并控制碰撞时的能量分配情况
          },
          "collision_engine": {
            "id": "engine",
            "type": "box",
            "material": "machine_max:structural_steel",
            "thickness": 1,
            "subsystem": "subsystem.machine_max.engine"
          }
        },
        "interact_boxes": {
          "interact.machine_max.glove_box": { //键:交互判定区名称
            "bone": "GloveBoxInteract", //骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "glove_box_interact": ["subsystem.machine_max.glove_box"] //将交互信号转发给储物子系统
            },
            "interact_mode": "accurate" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          }
        },
        "subsystems": {
          "subsystem.machine_max.car_controller": {
            "type": "machine_max:car_controller", //子系统类型
            "definition": "machine_max:van_car_controller",//子系统型号, 需要与子系统类型相匹配
            "control_outputs": {
              "car_control": [
                "subsystem.machine_max.engine",
                "subsystem.machine_max.gearbox",
                "subsystem.machine_max.left_back_wheel_driver",
                "subsystem.machine_max.left_front_wheel_driver",
                "subsystem.machine_max.right_back_wheel_driver",
                "subsystem.machine_max.right_front_wheel_driver"
              ]
            },
            "speed_outputs": { //(可选, 默认将移动速度(m/s)发至部件和载具的vehicle_speed频道)移动速度信号输出频道及目标
              "vehicle_speed": ["subpart", "vehicle"]
            },
            "throttle_outputs": { //(可选, 默认将油门[0,1]发至部件和载具的throttle频道)油门信号输出频道及目标
              "throttle": ["subpart", "vehicle"]
            },
            "brake_outputs": { //(可选, 默认将制动程度[0,1]发至部件和载具的brake频道)制动信号输出频道及目标
              "brake": ["subpart", "vehicle"]
            },
            "steering_outputs": { //(可选, 默认将转向程度[-1,1]发至部件和载具的steering频道)转向角度信号输出频道及目标
              "steering": ["subpart", "vehicle"]
            },
            "handbrake_outputs": { //(可选, 默认将手刹程度[0,1]发至部件和载具的handbrake频道)手刹器开关信号输出频道及目标
              "handbrake": ["subpart", "vehicle"]
            }
          },
          "subsystem.machine_max.engine": {
            "type": "machine_max:engine", //电动机子系统, 低速下恒扭矩, 高速下恒功率
            "definition": "machine_max:van_engine",//子系统型号, 需要与子系统类型相匹配
            "power_output": "subsystem.machine_max.gearbox", //功率输出目标, 可填写任意本部件内其他子系统名称、部件连接点名称, 或“part”, 或“vehicle”
            "speed_outputs": { //(可选, 默认将引擎转速(rad/s)发至部件和载具的engine_speed频道)引擎转速信号输出频道及目标
              "engine_speed": ["subpart", "vehicle"]
            }
          },
          "subsystem.machine_max.gearbox": {
            "type": "machine_max:gearbox", //变速箱子系统, 改变收到的功率信号的扭矩和转速
            "definition": "machine_max:van_gearbox", //子系统型号, 需要与子系统类型相匹配
            "power_output": "subsystem.machine_max.transmission", //功率输出目标, 子系统或部件连接点名
            "gear_outputs": { //(可选, 默认将当前挡位名称发至部件和载具的gear频道)挡位名称输出频道及目标
              "gear": ["subpart", "vehicle"]
            }
          },
          "subsystem.machine_max.glove_box": {
            "type": "machine_max:item_storage", //储物子系统, 互动可打开存储容器
            "definition": "machine_max:glove_box" //子系统型号, 需要与子系统类型相匹配
          },
          "subsystem.machine_max.transmission": {
            "type": "machine_max:transmission", //传动子系统, 将接收到的功率分配至各个输出目标
            "definition": "machine_max:van_transmission", //子系统型号, 需要与子系统类型相匹配
            "power_outputs": { //动力输出目标及减速比
              "subsystem.machine_max.left_front_wheel_driver": 1,
              "subsystem.machine_max.right_front_wheel_driver": 1
            }
          },
          "subsystem.machine_max.left_front_wheel_driver": {
            "type": "machine_max:wheel_driver", //轮胎驱动子系统, 驱动连接点上的部件滚动和转向
            "definition": "machine_max:van_front_wheel_driver", //子系统型号, 需要与子系统类型相匹配
            "connector": "connector.machine_max.left_front_wheel" //控制的连接点名称
          },
          "subsystem.machine_max.right_front_wheel_driver": {
            "type": "machine_max:wheel_driver", //轮胎驱动子系统, 驱动连接点上的部件滚动和转向
            "definition": "machine_max:van_front_wheel_driver", //子系统型号, 需要与子系统类型相匹配
            "connector": "connector.machine_max.right_front_wheel" //控制的连接点名称
          }
        },
        "connectors": {
          "connector.machine_max.hull_locator_chassis": {
            "locator": "chassis_hull",
            "definition": "machine_max:fixed_up",
            "signal_targets": { //向各个座椅传输来自车门的互动信号
              "interact_left_front_door": ["connector.machine_max.left_front_seat"],
              "interact_right_front_door": ["connector.machine_max.right_front_seat"],
              "interact_left_back_door": ["connector.machine_max.left_back_seat"],
              "interact_right_back_door": ["connector.machine_max.right_back_seat"]
            }
          },
          "connector.machine_max.left_front_wheel": {
            "locator": "left_front_wheel",
            "definition": "machine_max:van_left_front_wheel"
          },
          "connector.machine_max.right_front_wheel": {
            "locator": "right_front_wheel",
            "definition": "machine_max:van_right_front_wheel"
          },
          "connector.machine_max.left_back_wheel": {
            "locator": "left_back_wheel",
            "definition": "machine_max:van_left_back_wheel"
          },
          "connector.machine_max.right_back_wheel": {
            "locator": "right_back_wheel",
            "definition": "machine_max:van_right_back_wheel"
          },
          "connector.machine_max.left_front_seat": {
            "locator": "chassis_left_front_seat",
            "definition": "machine_max:fixed_up",
            "signal_targets": {
              "move_control": [
                "subsystem.machine_max.car_controller" //向控制器传输标准移动输入信号, 如转向、加速、刹车等
              ],
              "regular_control": ["subsystem.machine_max.car_controller"] //向车辆控制器传输一般按键输入信号, 如换挡、离合器控制等
            }
          },
          "connector.machine_max.right_front_seat": {
            "locator": "chassis_right_front_seat",
            "definition": "machine_max:fixed_up"
          },
          "connector.machine_max.left_back_seat": {
            "locator": "chassis_left_back_seat",
            "definition": "machine_max:fixed_up"
          },
          "connector.machine_max.right_back_seat": {
            "locator": "chassis_right_back_seat",
            "definition": "machine_max:fixed_up"
          }
        },
        "projected_area": [8.6, 13.9, 6.5],
        "hydro_priority": 10,
        "hydrodynamics": {
          "": {
            "front_drag": [0.0, 0.3],
            "back_drag": [0.0, 0.5]
          }
        }
      }
    }
  }
}