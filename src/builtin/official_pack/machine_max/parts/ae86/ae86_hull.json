{
  "$schema": "../../docs/zh_cn/schemas/part_definition_schema.json",
  "icon": "machine_max:textures/icon/ae86/ae86_hull_icon.png",//(可选, 留空会使用紫黑格子)部件图标路径
  "vehicle_durability_rate": 0.6,//(可选, 默认0.8)载具耐久贡献系数, 部件耐久度按此比例贡献给载具总耐久度
  "vehicle_damage_rate": 1.0,//(可选, 默认1.0)常态载具伤害传导系数, 部件受到伤害时按此比例传导给载具
  "vehicle_damage_rate_destroyed": 0.1,//(可选, 默认0.1)部件被摧毁后的载具伤害传导系数, 部件被摧毁后受到伤害时按此比例传导给载具
  "variants": {
    "model": "machine_max:ae86_hull.geo",//模型路径
    "textures": { //贴图路径列表
      "print.machine_max.ae86.1": "machine_max:textures/part/ae86/ae86_1.png",
      "print.machine_max.ae86.2": "machine_max:textures/part/ae86/ae86_2.png",
      "print.machine_max.ae86.3": "machine_max:textures/part/ae86/ae86_3.png",
      "print.machine_max.ae86.4": "machine_max:textures/part/ae86/ae86_4.png",
      "print.machine_max.ae86.5": "machine_max:textures/part/ae86/ae86_5.png",
      "print.machine_max.ae86.6": "machine_max:textures/part/ae86/ae86_6.png",
      "print.machine_max.ae86.7": "machine_max:textures/part/ae86/ae86_7.png",
      "print.machine_max.ae86.8": "machine_max:textures/part/ae86/ae86_8.png",
      "print.machine_max.ae86.9": "machine_max:textures/part/ae86/ae86_9.png"
    },
    "animations": "machine_max:empty", //(可选, 留空则不播放动画)动画路径
    "tags": ["machine_max:ae86", "machine_max:hull", "machine_max:storage"],//(可选, 默认[])部件标签列表
    "sub_parts": {//零件(子部件)列表
      "sub_part.machine_max.main": {//零件(子部件)名称
        "durability": 400.0,//(可选, 默认20.0)部件基础生命值, 降至0时部件的所有子系统会瘫痪
        "mass": 180.0,//零件质量(kg)
        "block_collision": "ground",//(可选)地形碰撞模式:true(默认, 与所有方块碰撞),ground(仅与部件之下的地面方块碰撞),false(不与任何方块碰撞)
        "collision_height": 2.5,//(可选)碰撞检测高度(m), 遭遇的障碍小于此高度时不与障碍发生碰撞(方块碰撞模式需要为ground), 默认所有障碍均碰撞
        "hit_boxes": {//键:骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体
          "CollisionShape": {
            "id": "part",
            "type": "box",
            "material": "machine_max:structural_steel",
            "thickness": 2
          }
        },
        "interact_boxes": {//交互判定区列表
          "interact.machine_max.left_front_door": { //键:交互判定区名称
            "bone": "LeftFrontDoorInteractZone", //骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "interact_left_front_door": ["connector.machine_max.chassis_connection"] //将交互信号转发给车架连接点
            },
            "interact_mode": "fast" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          },
          "interact.machine_max.right_front_door": { //键:交互判定区名称
            "bone": "RightFrontDoorInteractZone", //骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "interact_right_front_door": ["connector.machine_max.chassis_connection"] //将交互信号转发给车架连接点
            },
            "interact_mode": "fast" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          },
          "interact.machine_max.left_back_door": { //键:交互判定区名称
            "bone": "LeftBackDoorInteractZone", //骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "interact_left_back_door": ["connector.machine_max.chassis_connection"] //将交互信号转发给车架连接点
            },
            "interact_mode": "fast" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          },
          "interact.machine_max.right_back_door": { //键:交互判定区名称
            "bone": "RightBackDoorInteractZone", //骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "interact_right_back_door": ["connector.machine_max.chassis_connection"] //将交互信号转发给车架连接点
            },
            "interact_mode": "fast" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          },
          "interact.machine_max.trunk": {//键:交互判定区名称
            "bone": "TrunkInteractZone",//骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "trunk_interact": ["subsystem.machine_max.trunk"] //将交互信号转发给与车体连接的连接点
            },
            "interact_mode": "accurate" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          }
        },
        "subsystems": {//(可选)子系统配置
          "subsystem.machine_max.trunk": {
            "type": "machine_max:item_storage",
            "definition": "machine_max:default_trunk" //子系统型号, 需要与子系统类型相匹配
          }
        },
        "connectors": {//子部件用于与其他零件连接的连接点列表
          "connector.machine_max.chassis_connection": { //连接点名称
            "locator": "AttachPoint",//Locator名称, 会寻找名称匹配的Locator, 以其位置与姿态作为连接点的位置和姿态
            "definition": "machine_max:fixed_down"
          },
          "connector.machine_max.upper_engine":{
            "locator": "UpperEngine",
            "definition": "machine_max:fixed_up"
          },
          "connector.machine_max.front_engine":{
            "locator": "FrontEngine",
            "definition": "machine_max:fixed_front"
          },
          "connector.machine_max.right_back":{
            "locator": "RightBack",
            "definition": "machine_max:fixed_right"
          },
          "connector.machine_max.left_back":{
            "locator": "LeftBack",
            "definition": "machine_max:fixed_left"
          }
        },
        "hydro_priority": 10, //(可选, 默认0)空气阻力计算优先级, 值越大优先级越高, 优先级高的部件不会被优先级低的部件阻挡而导致阻力系数发生变化
        "hydrodynamics": {//(可选, 默认单点质心位置计算流体动力)流体动力计算定位点列表, 键值对的键名为空字符串时表示以质心位置计算
          "": {//流体动力计算点定位器名, 空字符串代表质心
            "scale": 1.0,//(可选, 默认1.0)整体上缩放流体动力的作用效果, 以多点而非单点计算流体动力时可相应调整此数值以确保数值可靠
            "transonic_amplifier": 5.0,//(可选, 默认5.0)跨声速段的阻力缩放因子, 当来流速度达到0.8~1.2马赫时, 阻力系数会逐渐从1x缩放到此倍数
            "front_drag": [0.0,0.25],//(可选, 默认[0.0,1.0])前向各阶阻力系数, 默认值下部件在前进时受到0.5*ρ*S*(0.1v+1.0v^2)的阻力, 其中ρ为空气密度, S为Z向(前后方向)投影面积, v为前进速度
            "back_drag": [0.0,0.4],//(可选, 默认[0.0,1.0])后向各阶阻力系数, 默认值下部件在后退时受到0.5*ρ*S*(0.1v+1.0v^2)的阻力, 其中ρ为空气密度, S为Z向(前后方向)投影面积, v为后退速度
            "left_drag": [0.0,1.0],//(可选, 默认[0.0,1.0])左向各阶阻力系数, 默认值下部件在左移时受到0.5*ρ*S*(0.1v+1.0v^2)的阻力, 其中ρ为空气密度, S为Y向(前后方向)投影面积, v为左移速度
            "right_drag": [0.0,1.0],//(可选, 默认[0.0,1.0])右向各阶升力系数, 默认值下部件在右移时受到0.5*ρ*S*(0.1v+1.0v^2)的阻力, 其中ρ为空气密度, S为Y向(前后方向)投影面积, v为右移速度
            "up_drag": [0.0,1.0],//(可选, 默认[0.0,1.0])上向各阶阻力系数, 默认值下部件在上升时受到0.5*ρ*S*(0.1v+1.0v^2)的阻力, 其中ρ为空气密度, S为X向(前后方向)投影面积, v为上升速度
            "down_drag": [0.0,1.0]//(可选, 默认[0.0,1.0])下向各阶阻力系数, 默认值下部件在坠落时受到0.5*ρ*S*(0.1v+1.0v^2)的阻力, 其中ρ为空气密度, S为X向(前后方向)投影面积, v为下降速度
          }
        }
      }
    }
  }
}