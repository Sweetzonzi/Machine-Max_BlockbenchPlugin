{
  "$schema": "../../docs/zh_cn/schemas/part_definition_schema.json",
  "icon": "machine_max:textures/icon/ae86/ae86_chassis_all_terrain_icon.png",//(可选, 留空会使用紫黑格子)部件图标路径
  "vehicle_durability_rate": 1.0,//(可选, 默认0.8)载具耐久贡献系数, 部件耐久度按此比例贡献给载具总耐久度
  "vehicle_damage_rate": 1.0,//(可选, 默认1.0)常态载具伤害传导系数, 部件受到伤害时按此比例传导给载具
  "vehicle_damage_rate_destroyed": 0.1,//(可选, 默认0.1)部件被摧毁后的载具伤害传导系数, 部件被摧毁后受到伤害时按此比例传导给载具
  "variants": {//部件变体列表, 可有多个变体名和模型路径的键值对
    "model": "machine_max:ae86_chassis_all_terrain.geo",//模型路径
    "textures": { //贴图路径列表
      "print.machine_max.ae86at.1": "machine_max:textures/part/ae86/ae86_all_terrain_1.png",
      "print.machine_max.ae86at.2": "machine_max:textures/part/ae86/ae86_all_terrain_2.png",
      "print.machine_max.ae86at.3": "machine_max:textures/part/ae86/ae86_all_terrain_3.png",
      "print.machine_max.ae86at.4": "machine_max:textures/part/ae86/ae86_all_terrain_4.png"
    },
    "animations": "machine_max:ae86", //(可选, 留空则不播放动画)动画路径
    "tags": ["machine_max:ae86", "machine_max:chassis"],//(可选)部件标签列表
    "sub_parts": {//零件(子部件)列表, 这是部件运动的最小单元, 部件的每个可动部分都应当是一个零件(子部件)
      "sub_part.machine_max.main": {//零件(子部件)名称
        "durability": 550.0,//(可选, 默认20.0)部件基础生命值, 降至0时部件的所有子系统会瘫痪
        "mass": 550.0,//零件质量(kg)
        "block_collision": "ground",//(可选)地形碰撞模式:true(默认, 与所有方块碰撞),ground(仅与部件之下的地面方块碰撞),false(不与任何方块碰撞)
        "collision_height": 3,//(可选)碰撞检测高度(m), 遭遇的障碍小于此高度时不与障碍发生碰撞(方块碰撞模式需要为ground), 默认所有障碍均碰撞
        "hit_boxes": {//键:骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体, 以及将此骨骼下的定位器储存起来供子系统等使用
          "mmCollision_Box_Chassis": {//值:碰撞形状属性
            "id": "chassis",//(可选, 默认"")同id的碰撞体积不会被同一次攻击多次伤害
            "type": "box",//碰撞形状类型, 支持box、sphere、cylinder
            "material": "machine_max:structural_steel",
            "thickness": 10 //(可选, 默认1)等效护甲厚度, 单位mm, 减免伤害并控制碰撞时的能量分配情况
          },
          "mmCollision_Box_Engine": {//值:碰撞形状属性
            "id": "engine",//(可选, 默认"")同id的碰撞体积不会被同一次攻击多次伤害
            "type": "box",//碰撞形状类型, 支持box、sphere、cylinder
            "subsystem": "subsystem.machine_max.engine",
            "material": "machine_max:structural_steel",
            "thickness": 3 //(可选, 默认1)等效护甲厚度, 单位mm, 减免伤害并控制碰撞时的能量分配情况
          }
        },
        "subsystems": {
          "subsystem.machine_max.car_controller": {
            "type": "machine_max:car_controller", //子系统类型
            "definition": "machine_max:ae86at_car_controller", //子系统型号, 需要与子系统类型相匹配
            "control_outputs": {
              "car_control": [
                "subsystem.machine_max.engine",
                "subsystem.machine_max.gearbox",
                "subsystem.machine_max.left_back_wheel_driver",
                "subsystem.machine_max.left_front_wheel_driver",
                "subsystem.machine_max.right_back_wheel_driver",
                "subsystem.machine_max.right_front_wheel_driver"
              ]
            },
            "speed_outputs": { //(可选, 默认将移动速度(m/s)发至部件和载具的vehicle_speed频道)移动速度信号输出频道及目标
              "vehicle_speed": ["subpart", "vehicle"]
            },
            "throttle_outputs": { //(可选, 默认将油门[0,1]发至部件和载具的throttle频道)油门信号输出频道及目标
              "throttle": ["subpart", "vehicle"]
            },
            "brake_outputs": { //(可选, 默认将制动程度[0,1]发至部件和载具的brake频道)制动信号输出频道及目标
              "brake": ["subpart", "vehicle"]
            },
            "steering_outputs": { //(可选, 默认将转向程度[-1,1]发至部件和载具的steering频道)转向角度信号输出频道及目标
              "steering": ["subpart", "vehicle"]
            },
            "handbrake_outputs": { //(可选, 默认将手刹程度[0,1]发至部件和载具的handbrake频道)手刹器开关信号输出频道及目标
              "handbrake": ["subpart", "vehicle"]
            }
          },
          "subsystem.machine_max.engine": {
            "type": "machine_max:engine", //子系统类型
            "definition": "machine_max:ae86at_engine", //子系统型号, 需要与子系统类型相匹配
            "power_output": "subsystem.machine_max.gearbox", //功率输出目标, 可填写任意本部件内其他子系统名称、部件连接点名称, 或“part”, 或“vehicle”
            "speed_outputs": { //(可选, 默认将引擎转速(rad/s)发至部件和载具的engine_speed频道)引擎转速信号输出频道及目标
              "engine_speed": ["subpart", "vehicle"]
            }
          },
          "subsystem.machine_max.gearbox": {
            "type": "machine_max:gearbox", //子系统类型
            "definition": "machine_max:ae86at_gearbox", //子系统型号, 需要与子系统类型相匹配
            "power_output": "subsystem.machine_max.transmission", //功率输出目标, 子系统或部件连接点名
            "gear_outputs": { //(可选, 默认将当前挡位名称发至部件和载具的gear频道)挡位名称输出频道及目标
              "gear": ["subpart", "vehicle"]
            }
          },
          "subsystem.machine_max.transmission": {//针对越野需求改装过的传动系统, 四轮驱动
            "type": "machine_max:transmission", //传动子系统, 将接收到的功率分配至各个输出目标
            "definition": "machine_max:ae86at_transmission", //子系统型号, 需要与子系统类型相匹配
            "power_outputs": { //动力输出目标及减速比
              "subsystem.machine_max.left_front_wheel_driver": 1.0,
              "subsystem.machine_max.right_front_wheel_driver": 1.0,
              "subsystem.machine_max.left_back_wheel_driver": 1.0,
              "subsystem.machine_max.right_back_wheel_driver": 1.0
            }
          },
          "subsystem.machine_max.left_front_wheel_driver": {
            "type": "machine_max:wheel_driver", //轮胎驱动子系统, 驱动连接点上的部件滚动和转向
            "definition": "machine_max:ae86at_front_wheel_driver", //子系统型号, 需要与子系统类型相匹配
            "connector": "connector.machine_max.left_front_wheel" //控制的连接点名称
          },
          "subsystem.machine_max.right_front_wheel_driver": {
            "type": "machine_max:wheel_driver", //轮胎驱动子系统, 驱动连接点上的部件滚动和转向
            "definition": "machine_max:ae86at_front_wheel_driver", //子系统型号, 需要与子系统类型相匹配
            "connector": "connector.machine_max.right_front_wheel"
          },
          "subsystem.machine_max.left_back_wheel_driver": {
            "type": "machine_max:wheel_driver",
            "definition": "machine_max:ae86at_back_wheel_driver",
            "connector": "connector.machine_max.left_back_wheel"
          },
          "subsystem.machine_max.right_back_wheel_driver": {
            "type": "machine_max:wheel_driver",
            "definition": "machine_max:ae86at_back_wheel_driver",
            "connector": "connector.machine_max.right_back_wheel"
          }
        },
        "connectors": {//子部件用于与其他零件连接的连接点列表
          "connector.machine_max.left_front_wheel": {//连接点名称
            "locator": "LeftFrontWheel",//Locator名称, 会寻找名称匹配的Locator, 以其位置与姿态作为连接点的位置和姿态
            "definition": "machine_max:ae86at_left_front_wheel"
          },
          "connector.machine_max.left_back_wheel": {
            "locator": "LeftBackWheel",
            "definition": "machine_max:ae86at_left_back_wheel"
          },
          "connector.machine_max.right_front_wheel": {
            "locator": "RightFrontWheel",
            "definition": "machine_max:ae86at_right_front_wheel"
          },
          "connector.machine_max.right_back_wheel": {
            "locator": "RightBackWheel",
            "definition": "machine_max:ae86at_right_back_wheel"
          },
          "connector.machine_max.hull": {
            "locator": "Hull",
            "definition": "machine_max:fixed_up",
            "signal_targets": { //向各个座椅传输来自车门的互动信号
              "interact_left_front_door": ["connector.machine_max.copilot_seat"],
              "interact_right_front_door": ["connector.machine_max.driver_seat"],
              "interact_left_back_door": ["connector.machine_max.back_seat"],
              "interact_right_back_door": ["connector.machine_max.back_seat"]
            }
          },
          "connector.machine_max.driver_seat": {
            "locator": "DriverSeat",
            "definition": "machine_max:fixed_up",
            "signal_targets": {
              "move_control": [
                "subsystem.machine_max.car_controller" //向控制器传输标准移动输入信号, 如转向、加速、刹车等
              ],
              "regular_control": ["subsystem.machine_max.car_controller"]//向车辆控制器传输一般按键输入信号, 如换挡、离合器控制等
            }
          },
          "connector.machine_max.copilot_seat": {
            "locator": "CopilotSeat",
            "definition": "machine_max:fixed_up"
          },
          "connector.machine_max.back_seat": {
            "locator": "BackSeat",
            "definition": "machine_max:fixed_up"
          }
        },
        "hydrodynamics": { //(可选, 默认单点质心位置计算流体动力)流体动力计算定位点列表, 键值对的键名为空字符串时表示以质心位置计算
          "AeroDynamicCenter": {//流体动力计算点定位器名, 空字符串代表质心
            "effective_range": 5.0 //(可选, 默认1.0)有效计算范围, 单位为m, 当在来流方向上的此距离内检测到遮挡时将会降低部件的实际空气阻力系数, 以模拟如车壳遮挡整流带来的减阻效果
          }
        }
      }
    }
  }
}