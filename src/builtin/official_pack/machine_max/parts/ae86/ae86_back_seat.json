{
  "$schema": "../../docs/zh_cn/schemas/part_definition_schema.json",
  "icon": "machine_max:textures/icon/ae86/ae86_back_seat_icon.png",//(可选, 留空会使用紫黑格子)部件图标路径
  "vehicle_durability_rate": 0.5,//(可选, 默认0.8)载具耐久贡献系数, 部件耐久度按此比例贡献给载具总耐久度
  "vehicle_damage_rate": 0.5,//(可选, 默认1.0)常态载具伤害传导系数, 部件受到伤害时按此比例传导给载具
  "vehicle_damage_rate_destroyed": 0.0,//(可选, 默认0.1)部件被摧毁后的载具伤害传导系数, 部件被摧毁后受到伤害时按此比例传导给载具
  "variants": {
    "model": "machine_max:ae86_back_seat.geo",//模型路径
    "textures": "machine_max:textures/part/ae86/ae86_all_terrain_1.png",
    "animations": "machine_max:empty",//(可选, 留空则不播放动画)动画路径
    "tags": ["machine_max:ae86"],//(可选, 默认[])部件标签列表
    "sub_parts": {//零件(子部件)列表
      "sub_part.machine_max.main": {//零件(子部件)名称
        "durability": 100.0,//(可选, 默认20.0)部件基础生命值, 降至0时部件的所有子系统会瘫痪
        "mass": 35.0,//零件质量(kg)
        "block_collision": "ground",//(可选)地形碰撞模式:true(默认, 与所有方块碰撞),ground(仅与部件之下的地面方块碰撞),false(不与任何方块碰撞)
        "collision_height": 2.5,//(可选)碰撞检测高度(m), 遭遇的障碍小于此高度时不与障碍发生碰撞(方块碰撞模式需要为ground), 默认所有障碍均碰撞
        "hit_boxes": {//键:骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体, 以及将此骨骼下的定位器储存起来供子系统等使用
          "CollisionShape": {//值:碰撞形状属性
            "type": "box",//碰撞形状类型, 支持box、sphere、cylinder
            "material": "machine_max:structural_steel",
            "thickness": 1 //(可选, 默认1)等效护甲厚度, 单位mm, 减免伤害并控制碰撞时的能量分配情况
          }
        },
        "interact_boxes": {//交互判定区列表
          "interact.machine_max.left_seat": {//键:交互判定区名称
            "bone": "LeftInteractShape",//骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "interact": ["subsystem.machine_max.left_seat"] //将交互信号转发给座椅子系统
            },
            "interact_mode": "accurate" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          },
          "interact.machine_max.right_seat": {//键:交互判定区名称
            "bone": "RightInteractShape",//骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "interact": ["subsystem.machine_max.right_seat"] //将交互信号转发给座椅子系统
            },
            "interact_mode": "accurate" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          }
        },
        "subsystems": {//(可选)子系统配置
          "subsystem.machine_max.left_seat": {
            "type": "machine_max:seat",
            "definition": "machine_max:default_passenger_seat", //子系统型号, 需要与子系统类型相匹配
            "locator": "LeftSeatPoint",//乘坐点定位器名称, 该定位器需要位于任意零件的碰撞箱骨骼中, 乘客将被定位于此
            "passenger_num_outputs": {
              "left_occupied": ["interact.machine_max.left_seat", "connector.machine_max.chassis_connection"]
            }
          },
          "subsystem.machine_max.right_seat": {
            "type": "machine_max:seat",
            "definition": "machine_max:default_passenger_seat", //子系统型号, 需要与子系统类型相匹配
            "locator": "RightSeatPoint",//乘坐点定位器名称, 该定位器需要位于任意零件的碰撞箱骨骼中, 乘客将被定位于此
            "passenger_num_outputs": {
              "right_occupied": ["interact.machine_max.right_seat", "connector.machine_max.chassis_connection"]
            }
          }
        },
        "connectors": {//子部件用于与其他零件连接的连接点列表
          "connector.machine_max.chassis_connection": {//连接点名称
            "locator": "AttachPoint",//Locator名称, 会寻找名称匹配的Locator, 以其位置与姿态作为连接点的位置和姿态
            "definition": "machine_max:fixed_down",
            "signal_translations": {//将各个类型的频道的信号转换至interact频道，统一信号频道
              "interact_left_front_door": "left_interact",
              "interact_right_front_door": "right_interact",
              "interact_left_back_door": "left_interact",
              "interact_right_back_door": "right_interact",
              "interact_left_door": "left_interact",
              "interact_right_door": "right_interact"
            },
            "signal_targets": {//向座椅子系统传输来自车门的互动信号
              "left_interact": ["subsystem.machine_max.left_seat"],
              "right_interact": ["subsystem.machine_max.right_seat"]
            }
          }
        },
        "hydro_priority": 0, //(可选, 默认0)空气阻力计算优先级, 值越大优先级越高, 优先级高的部件不会被优先级低的部件阻挡而导致阻力系数发生变化
        "hydrodynamics": { //(可选, 默认单点质心位置计算流体动力)流体动力计算定位点列表, 键值对的键名为空字符串时表示以质心位置计算
          "": {//流体动力计算点定位器名, 空字符串代表质心
            "effective_range": 5.0 //(可选, 默认1.0)有效计算范围, 单位为m, 当在来流方向上的此距离内检测到遮挡时将会降低部件的实际空气阻力系数, 以模拟如车壳遮挡整流带来的减阻效果
          }
        }
      }
    }
  }
}