{
  "$schema": "../../docs/zh_cn/schemas/part_definition_schema.json",
  "icon": "machine_max:textures/icon/wine_fox/wine_fox_trunk_door_icon.png",//(可选, 留空会使用紫黑格子)部件图标路径
  "vehicle_durability_rate": 1.0,//(可选, 默认1.0)载具耐久贡献系数, 部件耐久度按此比例贡献给载具总耐久度
  "vehicle_damage_rate": 0.5,//(可选, 默认1.0)常态载具伤害传导系数, 部件受到伤害时按此比例传导给载具
  "vehicle_damage_rate_destroyed": 0.1,//(可选, 默认0.5)部件被摧毁后的载具伤害传导系数, 部件被摧毁后受到伤害时按此比例传导给载具
  "variants": {//部件变体列表, 支持单值或多键值对
    "model": "machine_max:wine_fox.geo", //模型路径
    "textures": "machine_max:textures/part/wine_fox/wine_fox.png",
    "animations": "machine_max:wine_fox",
    "tags": ["machine_max:trunk", "machine_max:wine_fox"],//(可选)部件标签列表
    "sub_parts": {//零件(子部件)列表
      "sub_part.machine_max.main": {//零件(子部件)名称
        "start_bone": "Trunk", // (可选，默认空)起始骨骼名称，此骨骼及其包含的骨骼才会被作为零件的渲染与定义用模型
        "durability": 50.0,//(可选, 默认20.0)部件基础生命值, 降至0时部件的所有子系统会瘫痪
        "mass": 10.0,//零件质量(kg)
        "block_collision": "ground",//(可选, 默认true)地形碰撞模式:true(与所有方块碰撞),ground(仅与低于部件最低位置的地面方块碰撞),false(不与任何方块碰撞)
        "collision_height": 1.5,//(可选)碰撞检测高度(m), 遭遇的障碍小于此高度时不与障碍发生碰撞(方块碰撞模式需要为ground), 默认所有障碍均碰撞
        "hit_boxes": {//键:骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体, 以及将此骨骼下的定位器储存起来供子系统等使用
          "TrunkHitBox": {//骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体
            "type": "box",//碰撞形状类型, 支持box、sphere、cylinder、wheel
            "material": "machine_max:structural_steel"
          },
          "BackGlass": { // 挡风玻璃
            "id": "glass",
            "type": "box",
            "thickness": 0,
            "material": "machine_max:glass",
            "subsystem": "subsystem.machine_max.glass",
            "condition": "!subpart.subsystem_destroyed('subsystem.machine_max.glass')" // 仅当前挡风玻璃未被摧毁时才生效
          },
          "TrunkLeftLight": {
            "type": "box",
            "thickness": 0,
            "material": "machine_max:glass",
            "subsystem": "subsystem.machine_max.left_back_light",
            "condition": "!subpart.subsystem_destroyed('subsystem.machine_max.left_back_light')"
          },
          "TrunkRightLight": {
            "type": "box",
            "thickness": 0,
            "material": "machine_max:glass",
            "subsystem": "subsystem.machine_max.right_back_light",
            "condition": "!subpart.subsystem_destroyed('subsystem.machine_max.right_back_light')"
          }
        },
        "subsystems": {
          "subsystem.machine_max.glass": {
            "type": "machine_max:basic", //无功能子系统, 仅用于表示玻璃是否被摧毁
            "definition": "machine_max:default_glass"
          },
          "subsystem.machine_max.left_back_light": {
            "type": "machine_max:lighting",
            "definition": "machine_max:dummy_light"
          },
          "subsystem.machine_max.right_back_light": {
            "type": "machine_max:lighting",
            "definition": "machine_max:dummy_light"
          }
        },
        "connectors": {//子部件用于与其他零件连接的连接点列表
          "connector.machine_max.axis": {//连接点名称
            "locator": "trunk_door_hull_axis",//Locator名称, 会寻找名称匹配的Locator, 以其位置与姿态作为连接点的位置和姿态
            "definition": "machine_max:fixed_down"
          },
          "connector.machine_max.lock": {//连接点名称
            "locator": "trunk_door_hull_lock",//Locator名称, 会寻找名称匹配的Locator, 以其位置与姿态作为连接点的位置和姿态
            "definition": "machine_max:fixed_down",
            "overwrite": {
              "integrity": 5
            }
          }
        },
        "projected_area": [0.23, 0.35, 2.34],
        "hydrodynamics": {
          "": {
            "effective_range": 5,
            "front_drag": [0.0, 0.3],
            "back_drag": [0.0, 0.3]
          }
        }
      }
    }
  }
}