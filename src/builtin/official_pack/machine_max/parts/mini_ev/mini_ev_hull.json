{
  "$schema": "../../docs/zh_cn/schemas/part_definition_schema.json",
  "icon": "machine_max:textures/icon/mini_ev/mini_ev_hull_icon.png", //(可选, 留空会使用紫黑格子)部件图标路径
  "vehicle_durability_rate": 0.6, //(可选, 默认0.8)载具耐久贡献系数, 部件耐久度按此比例贡献给载具总耐久度
  "vehicle_damage_rate": 1.0, //(可选, 默认1.0)常态载具伤害传导系数, 部件受到伤害时按此比例传导给载具
  "vehicle_damage_rate_destroyed": 0.1, //(可选, 默认0.1)部件被摧毁后的载具伤害传导系数, 部件被摧毁后受到伤害时按此比例传导给载具
  "variants": { //部件变体列表, 可有多个变体名和模型路径的键值对
    "model": "machine_max:mini_ev_hull.geo",
    "textures": { //贴图路径列表
      "print.machine_max.white": "machine_max:textures/part/mini_ev/mini_ev_ae86.png",
      "print.machine_max.black": "machine_max:textures/part/mini_ev/mini_ev_black.png",
      "print.machine_max.brown": "machine_max:textures/part/mini_ev/mini_ev_brown.png",
      "print.machine_max.pink": "machine_max:textures/part/mini_ev/mini_ev_pink.png",
      "print.machine_max.mini_ev.white": "machine_max:textures/part/mini_ev/mini_ev_white.png"
    },
    "animations": "machine_max:mini_ev",
    "tags": ["machine_max:hull", "machine_max:mini_ev", "machine_max:storage"],//(可选, 默认[])部件标签列表
    "sub_parts": {//零件(子部件)列表
      "sub_part.machine_max.main": {//零件(子部件)名称
        "durability": 200.0, //(可选, 默认20.0)部件基础生命值, 降至0时部件的所有子系统会瘫痪
        "mass": 320.0, //零件质量(kg)
        "block_collision": "ground", //(可选)地形碰撞模式:true(默认, 与所有方块碰撞),ground(仅与部件之下的地面方块碰撞),false(不与任何方块碰撞)
        "collision_height": 1.5, //(可选)碰撞检测高度(m), 遭遇的障碍小于此高度时不与障碍发生碰撞(方块碰撞模式需要为ground), 默认所有障碍均碰撞
        "hit_boxes": { //键:骨骼名称, 会寻找名称匹配的骨骼, 并根据其中的方块创建不同形状的碰撞体, 以及将此骨骼下的定位器储存起来供子系统等使用
          "HullCollisionShape": { //值:碰撞形状属性
            "id": "part", //(可选, 默认"")同id的碰撞体积不会被同一次攻击多次伤害
            "type": "box", //碰撞形状类型, 支持box、sphere、cylinder
            "material": "machine_max:structural_steel",
            "thickness": 3 //(可选, 默认1)等效护甲厚度, 单位mm, 减免伤害并控制碰撞时的能量分配情况
          },
          "EngineCollisionShape": { //值:碰撞形状属性
            "id": "engine", //(可选, 默认"")同id的碰撞体积不会被同一次攻击多次伤害
            "type": "box", //碰撞形状类型, 支持box、sphere、cylinder
            "subsystem": "subsystem.machine_max.motor", //(可选, 默认"")子系统名称, 对此碰撞形状造成的伤害会等量地传导给此子系统, 若为空则不属于任何子系统
            "material": "machine_max:structural_steel",
            "thickness": 2 //(可选, 默认1)等效护甲厚度, 单位mm, 减免伤害并控制碰撞时的能量分配情况
          }
        },
        "interact_boxes": { //交互判定区列表
          "interact.machine_max.left_front_door": { //键:交互判定区名称
            "bone": "LeftFrontDoorInteractZone", //骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "interact_left_front_door": ["subsystem.machine_max.driver_seat"] //将交互信号转发给驾驶座
            },
            "interact_mode": "fast" //(可选, 默认fast)交互模式, fast为玩家碰撞箱与交互区碰撞时按下交互键触发, accurate为玩家瞄准交互区按下交互键触发
          },
          "interact.machine_max.right_front_door": {
            "bone": "RightFrontDoorInteractZone",
            "signal_targets": {
              "interact_left_back_door": ["subsystem.machine_max.copilot_seat"]
            },
            "interact_mode": "fast"
          },
          "interact.machine_max.left_back_door": {
            "bone": "LeftBackDoorInteractZone",
            "signal_targets": {
              "interact_right_front_door": ["subsystem.machine_max.left_back_seat"]
            },
            "interact_mode": "fast"
          },
          "interact.machine_max.right_back_door": {
            "bone": "RightBackDoorInteractZone",
            "signal_targets": {
              "interact_right_back_door": ["subsystem.machine_max.right_back_seat"]
            },
            "interact_mode": "fast"
          },
          "interact.machine_max.left_front_seat": {
            "bone": "LeftSeatInteractZone",
            "signal_targets": {
              "interact_left_front_door": ["subsystem.machine_max.driver_seat"]
            },
            "interact_mode": "accurate"
          },
          "interact.machine_max.right_front_seat": {
            "bone": "RightSeatInteractZone",
            "signal_targets": {
              "interact_left_back_door": ["subsystem.machine_max.copilot_seat"]
            },
            "interact_mode": "accurate"
          },
          "interact.machine_max.left_back_seat": { //键:交互判定区名称
            "bone": "LeftBackSeatInteractZone", //骨骼名称, 会寻找名称匹配的骨骼, 以其内部方块的位置与姿态作为交互判定区体积的位置和姿态
            "signal_targets": {
              "interact_right_front_door": ["subsystem.machine_max.left_back_seat"] //将交互信号转发给后排座椅
            },
            "interact_mode": "accurate"
          },
          "interact.machine_max.right_back_seat": {
            "bone": "RightBackSeatInteractZone",
            "signal_targets": {
              "interact_right_back_door": ["subsystem.machine_max.right_back_seat"]
            },
            "interact_mode": "accurate"
          },
          "interact.machine_max.glove_box": {
            "bone": "GloveBoxInteractZone",
            "signal_targets": {
              "interact_right_back_door": ["subsystem.machine_max.glove_box"]
            },
            "interact_mode": "accurate"
          }
        },
        "subsystems": {
          "subsystem.machine_max.driver_seat": {
            "type": "machine_max:seat", //子系统类型
            "definition": "machine_max:default_seat", //子系统型号, 需要与子系统类型相匹配
            "locator": "LeftFrontSeatPoint", //乘坐点定位器名称, 该定位器需要位于任意零件的碰撞箱骨骼中, 乘客将被定位于此
            "move_outputs": { //(可选,默认为空)子系统移动控制输出列表
              "move_control": ["subsystem.machine_max.car_controller"] //将控制信号转发给车辆控制系统
            },
            "regular_outputs": { //(可选,默认为空)子系统常规按键输出列表
              "regular_control": ["subsystem.machine_max.car_controller"]
            },
            "aim_outputs": { //(可选,默认为空)子系统视角控制输出列表
              "aim_control": ["subsystem.machine_max.car_controller"]
            },
            "passenger_num_outputs": {
              "occupied": ["interact.machine_max.left_front_door"]
            }
          },
          "subsystem.machine_max.copilot_seat": {
            "type": "machine_max:seat",
            "definition": "machine_max:default_passenger_seat",
            "locator": "RightFrontSeatPoint", //乘坐点定位器名称, 该定位器需要位于任意零件的碰撞箱骨骼中, 乘客将被定位于此
            "passenger_num_outputs": {
              "occupied": ["interact.machine_max.right_front_door"]
            }
          },
          "subsystem.machine_max.left_back_seat": {
            "type": "machine_max:seat",
            "definition": "machine_max:default_passenger_seat",
            "locator": "LeftBackSeatPoint",
            "passenger_num_outputs": {
              "occupied": ["interact.machine_max.left_back_door"]
            }
          },
          "subsystem.machine_max.right_back_seat": {
            "type": "machine_max:seat",
            "definition": "machine_max:default_passenger_seat",
            "locator": "RightBackSeatPoint",
            "passenger_num_outputs": {
              "occupied": ["interact.machine_max.right_back_door"]
            }
          },
          "subsystem.machine_max.car_controller": {
            "type": "machine_max:car_controller",
            "definition": "machine_max:mini_ev_car_controller",
            "control_outputs": {
              "car_control": [
                "subsystem.machine_max.left_back_wheel_driver",
                "subsystem.machine_max.left_front_wheel_driver",
                "subsystem.machine_max.motor",
                "subsystem.machine_max.right_back_wheel_driver",
                "subsystem.machine_max.right_front_wheel_driver"
              ]
            },
            "speed_outputs": { //(可选, 默认将移动速度(m/s)发至部件和载具的vehicle_speed频道)移动速度信号输出频道及目标
              "vehicle_speed": ["subpart", "vehicle"]
            },
            "throttle_outputs": { //(可选, 默认将油门[0,1]发至部件和载具的throttle频道)油门信号输出频道及目标
              "throttle": ["subpart", "vehicle"]
            },
            "brake_outputs": { //(可选, 默认将制动程度[0,1]发至部件和载具的brake频道)制动信号输出频道及目标
              "brake": ["subpart", "vehicle"]
            },
            "steering_outputs": { //(可选, 默认将转向程度[-1,1]发至部件和载具的steering频道)转向角度信号输出频道及目标
              "steering": ["subpart", "vehicle"]
            },
            "handbrake_outputs": { //(可选, 默认将手刹程度[0,1]发至部件和载具的handbrake频道)手刹器开关信号输出频道及目标
              "handbrake": ["subpart", "vehicle"]
            }
          },
          "subsystem.machine_max.motor": {
            "type": "machine_max:motor", //电动机子系统, 低速下恒扭矩, 高速下恒功率
            "definition": "machine_max:mini_ev_motor",
            "power_output": "subsystem.machine_max.transmission", //功率输出目标, 可填写任意本部件内其他子系统名称、部件连接点名称, 或“part”, 或“vehicle”
            "speed_outputs": { //(可选, 默认将引擎转速(rad/s)发至部件和载具的engine_speed频道)引擎转速信号输出频道及目标
              "engine_speed": ["subpart", "vehicle"]
            }
          },
          "subsystem.machine_max.transmission": {
            "type": "machine_max:transmission", //传动子系统, 将接收到的功率分配至各个输出目标
            "definition": "machine_max:mini_ev_transmission", //子系统型号, 需要与子系统类型相匹配
            "power_outputs": { //动力输出目标及减速比
              "subsystem.machine_max.left_back_wheel_driver": 8,
              "subsystem.machine_max.right_back_wheel_driver": 8
            }
          },
          "subsystem.machine_max.glove_box": {
            "type": "machine_max:item_storage", //储物子系统, 互动可打开存储容器
            "definition": "machine_max:glove_box" //子系统型号, 需要与子系统类型相匹配
          },
          "subsystem.machine_max.left_front_wheel_driver": {
            "type": "machine_max:wheel_driver", //轮胎驱动子系统, 驱动连接点上的部件滚动和转向
            "definition": "machine_max:mini_ev_front_wheel_driver", //子系统型号, 需要与子系统类型相匹配
            "connector": "connector.machine_max.left_front_wheel" //控制的连接点名称
          },
          "subsystem.machine_max.right_front_wheel_driver": {
            "type": "machine_max:wheel_driver", //轮胎驱动子系统, 驱动连接点上的部件滚动和转向
            "definition": "machine_max:mini_ev_front_wheel_driver", //子系统型号, 需要与子系统类型相匹配
            "connector": "connector.machine_max.right_front_wheel" //控制的连接点名称
          },
          "subsystem.machine_max.left_back_wheel_driver": {
            "type": "machine_max:wheel_driver",
            "definition": "machine_max:mini_ev_back_wheel_driver",
            "connector": "connector.machine_max.left_back_wheel"
          },
          "subsystem.machine_max.right_back_wheel_driver": {
            "type": "machine_max:wheel_driver",
            "definition": "machine_max:mini_ev_back_wheel_driver",
            "connector": "connector.machine_max.right_back_wheel"
          }
        },
        "connectors": { //子部件用于与其他零件连接的连接点列表
          "connector.machine_max.left_front_wheel": { //连接点名称
            "locator": "left_front_wheel", //Locator名称, 会寻找名称匹配的Locator, 以其位置与姿态作为连接点的位置和姿态
            "definition": "machine_max:mini_ev_left_front_wheel"
          },
          "connector.machine_max.left_back_wheel": {
            "locator": "left_back_wheel",
            "definition": "machine_max:mini_ev_left_back_wheel"
          },
          "connector.machine_max.right_front_wheel": {
            "locator": "right_front_wheel",
            "definition": "machine_max:mini_ev_right_front_wheel"
          },
          "connector.machine_max.right_back_wheel": {
            "locator": "right_back_wheel",
            "definition": "machine_max:mini_ev_right_back_wheel"
          },
          "connector.machine_max.back_left":{
          "locator": "BackLeft",
          "definition": "machine_max:fixed_left"
          },
          "connector.machine_max.back_right":{
            "locator": "BackRight",
            "definition": "machine_max:fixed_right"
          }
        },
        "projected_area": [8.57, 8.57, 5.94],
        "hydrodynamics": {
          "": {
            "front_drag": [0.1, 0.35],
            "back_drag": [0.1, 0.7]
          }
        }
      }
    }
  }
}