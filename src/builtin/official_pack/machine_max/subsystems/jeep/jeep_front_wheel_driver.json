{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:wheel_driver",
  "basic_durability": 500, //(可选, 默认20.0)子系统基础耐久度, 降至0时会瘫痪
  "roll": {//(可选)轮胎滚动相关属性, 默认最大驱动力矩10000N*m, 最大刹车力矩3500N*m, 最大手刹车力矩0N*m, 最大转速3140rad/s, 不反馈转速值到任何频道的任何目标
    "max_drive_force": 8000.0, //(可选, 默认10000)最大驱动力矩(N*m)
    "max_brake_force": 5000.0, //(可选, 默认3500)最大刹车力矩(N*m)
    "max_hand_brake_force": 0.0, //(可选, 默认0)最大手刹车力矩(N*m)
    "max_speed": 3140.0 //(可选, 默认3140)最大转速(rad/s)
  },
  "steering": {//(可选)轮胎转向相关属性, 默认最大转向力矩2000N*m, 最大转速3.14rad/s, 不反馈转角值到任何频道的任何目标
    "max_force": 3500,
    "max_speed": 1.9
  },
  "abs_enabled": true, //(可选, 默认false)是否启用ABS
  "abs_target_slip_ratio": 0.15, //(可选, 默认0.15)ABS目标滑移率
  "abs_wheel_radius": 0.672, //(可选, 默认0.3)轮胎半径(m)
  "control_inputs": ["car_control"] //(可选, 默认["car_control"])接收的控制信号的频道列表, 优先级递减
}