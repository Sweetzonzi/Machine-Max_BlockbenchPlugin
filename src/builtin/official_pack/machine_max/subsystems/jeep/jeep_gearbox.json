{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:gearbox",
  "basic_durability": 220, //(可选, 默认20.0)子系统基础耐久度, 降至0时会瘫痪
  "final_ratio": 10.0, //(可选, 默认10.0)最终变速比(主减速比), 用于整体缩放变速箱减速比
  "ratios": [-3.3, 4.71, 3.14, 2.1, 1.6, 1.29, 1.1, 0.88, 0.67], //(可选, 默认[-3.5, 3.5, 2.5, 1.7, 1.4, 1.1])各个挡位的传动比, 负代表反向传动即倒挡
  "switch_time": 0.2, //(可选, 默认0.3)换挡时间(s), 不踩离合换挡或自动挡换挡时触发, 此时无动力输出, 通过手动踩离合换挡可避免
  "control_inputs": ["car_control"] //(可选, 此为默认值)接收的控制信号的频道列表, 优先级递减
}