{
  "$schema": "../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:lighting", //照明子系统, 仅在客户端渲染视觉体积光, 不改变方块实际亮度
  "basic_durability": 2, //(可选, 默认20.0)子系统基础耐久度
  "hidden": true, //(可选, 默认false)是否在HUD等界面隐藏该子系统
  "light_type": "beam", //(可选, 默认beam)定向光束, 使用动态属性light_locator对应定位器的-Z方向作为前向
  "range": 16, //(可选, 默认16)光束长度
  "color": [255, 245, 210], //(可选, 默认[255,255,255])RGB颜色, 取值0-255
  "intensity": 0.5, //(可选, 默认1.0)光效强度, 取值0-1
  "beam_angle": 24 //(可选, 默认24)完整光锥张角, 单位为度
}
