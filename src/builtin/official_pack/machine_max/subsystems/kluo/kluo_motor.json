{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:motor", //电动机子系统, 低速下恒扭矩, 高速下恒功率
  "basic_durability": 50, //(可选, 默认20.0)子系统基础耐久度, 降至0时会瘫痪
  "max_power": 50000, //最大功率(W)
  "max_torque": 250, //(可选, 默认100)峰值扭矩(N·m), 实际输出扭矩(特别是转速较低时)
  "inertia": 2, //(可选, 默认10)转动惯量(kg·m^2), 此值越大, 引擎加速越慢, 存速越好
  "damping_factors": [10.0, 0.1, 0.0001] //(可选, 默认[10.0, 0.1, 0.00005])电机系统各阶阻力系数, 分别为常数项, 一次项, 二次项, …递增(N·m/(rad/s)^n)
}
