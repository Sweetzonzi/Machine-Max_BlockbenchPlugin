{
  "$schema": "../../docs/zh_cn/schemas/subsystem/subsystem_static_attr.schema.json",
  "type": "machine_max:car_controller", //子系统类型
  "basic_durability": 50,
  "steering_center": [0, 0, 1.96],
  "min_steering_radius": 4.0, //(可选, 默认5.0)最小转向半径，单位米。用于低速和手刹时的转向限制
  "lateral_acceleration": 60.0, //(可选, 默认8.0)侧向加速度限制，单位m/s²。用于根据速度实时计算转向半径（半径 = 速度² / 加速度）
  "max_drift_angular_velocity": 1.0 //(可选, 默认1.0)最大漂移角速度，单位rad/s。作为漂移时PD控制器的目标值
}